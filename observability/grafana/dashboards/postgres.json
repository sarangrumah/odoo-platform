{
  "title": "Postgres",
  "uid": "postgres",
  "tags": ["platform", "postgres"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Active connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(pg_stat_activity_count) by (datname)", "legendFormat": "{{datname}}", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 2,
      "title": "Cache hit ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "pg:cache_hit:ratio", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 3,
      "title": "Deadlocks (5m rate)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "rate(pg_stat_database_deadlocks[5m])", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 4,
      "title": "DB size",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "pg_database_size_bytes", "legendFormat": "{{datname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    }
  ]
}
