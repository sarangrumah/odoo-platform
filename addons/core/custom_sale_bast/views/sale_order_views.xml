<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_bast" model="ir.ui.view">
        <field name="name">sale.order.form.bast</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_bast" type="object"
                        class="oe_stat_button" icon="fa-handshake-o"
                        groups="custom_bast.group_bast_user">
                    <field name="bast_count" widget="statinfo" string="BAST"/>
                </button>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_generate_bast" type="object"
                        string="Generate BAST"
                        groups="custom_bast.group_bast_user"/>
            </xpath>

        </field>
    </record>

</odoo>
