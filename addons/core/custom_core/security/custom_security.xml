<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_custom_platform" model="ir.module.category">
            <field name="name">Custom Platform</field>
            <field name="description">Permissions for the Custom Odoo 19 Platform layer</field>
            <field name="sequence">100</field>
        </record>

        <record id="res_groups_privilege_custom_platform" model="res.groups.privilege">
            <field name="name">Custom Platform</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="module_category_custom_platform"/>
        </record>

        <record id="group_custom_user" model="res.groups">
            <field name="name">Custom / User</field>
            <field name="privilege_id" ref="res_groups_privilege_custom_platform"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_custom_admin" model="res.groups">
            <field name="name">Custom / Administrator</field>
            <field name="privilege_id" ref="res_groups_privilege_custom_platform"/>
            <field name="implied_ids" eval="[(4, ref('group_custom_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
