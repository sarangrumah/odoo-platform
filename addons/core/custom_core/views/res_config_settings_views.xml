<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_custom_core" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.custom_core</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Custom Platform" string="Custom Platform" name="custom_core"
                     groups="custom_core.group_custom_admin">
                    <block title="Overview">
                        <setting>
                            <field name="custom_platform_label" readonly="1" nolabel="1"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
