<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_custom_ai" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.custom_ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="custom_core.res_config_settings_view_form_custom_core"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='custom_core']" position="inside">
                <block title="AI Intelligence">
                    <setting string="Enable AI" help="Master switch for AI features platform-wide.">
                        <field name="custom_ai_enabled"/>
                    </setting>
                    <setting string="Default Quality">
                        <field name="custom_ai_default_quality"/>
                    </setting>
                    <setting string="Provider Override"
                             help="Pilih provider AI untuk tenant ini. Banner di bawah menjelaskan dampak biaya, latensi, dan data residency.">
                        <field name="custom_ai_provider_override"/>
                        <field name="custom_ai_provider_tradeoff_html" nolabel="1" readonly="1"/>
                    </setting>
                    <setting string="Ollama Model"
                             help="Override nama model Ollama. Hanya relevan saat Provider = Local Ollama."
                             invisible="custom_ai_provider_override != 'ollama'">
                        <field name="custom_ai_ollama_model" placeholder="qwen2.5:7b"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
