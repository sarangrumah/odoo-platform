<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_custom_ai" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.custom_ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="custom_core.res_config_settings_view_form_custom_core"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='custom_platform']" position="inside">
                <block title="AI Intelligence">
                    <setting string="Enable AI" help="Master switch for AI features platform-wide.">
                        <field name="custom_ai_enabled"/>
                    </setting>
                    <setting string="Default Quality">
                        <field name="custom_ai_default_quality"/>
                    </setting>
                    <setting string="Provider Override">
                        <field name="custom_ai_provider_override"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
