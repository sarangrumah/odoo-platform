<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_home_console" model="ir.ui.view">
        <field name="name">res.company.form.home.console</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Home Console" name="home_console">
                    <group>
                        <group string="Branding">
                            <field name="brand_accent_color" widget="color"/>
                            <field name="brand_logo_home" widget="image"
                                   options="{'preview_image': 'brand_logo_home'}"/>
                        </group>
                        <group string="Announcement">
                            <field name="home_announcement_active"/>
                            <field name="home_announcement_html"
                                   nolabel="1" colspan="2"
                                   invisible="not home_announcement_active"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
