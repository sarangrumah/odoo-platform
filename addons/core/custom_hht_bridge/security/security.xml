<odoo noupdate="0">

    <record id="module_category_hht" model="ir.module.category">
        <field name="name">Handheld Terminal</field>
        <field name="description">Access management for HHT bridge / PWA shell.</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_hht_operator" model="res.groups">
        <field name="name">HHT Operator</field>
        <field name="category_id" ref="module_category_hht"/>
        <field name="comment">Can use the PWA, view scan events of own device.</field>
    </record>

    <record id="group_hht_admin" model="res.groups">
        <field name="name">HHT Administrator</field>
        <field name="category_id" ref="module_category_hht"/>
        <field name="implied_ids" eval="[(4, ref('group_hht_operator'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Full control of devices, secrets, and global scan events.</field>
    </record>

    <!-- Record rule: Operator sees only their own user's device events. -->
    <record id="hht_scan_log_rule_operator" model="ir.rule">
        <field name="name">HHT Scan Log: Operator sees own device only</field>
        <field name="model_id" ref="model_hht_scan_log"/>
        <field name="groups" eval="[(4, ref('group_hht_operator'))]"/>
        <field name="domain_force">[('device_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hht_scan_log_rule_admin" model="ir.rule">
        <field name="name">HHT Scan Log: Admin sees all</field>
        <field name="model_id" ref="model_hht_scan_log"/>
        <field name="groups" eval="[(4, ref('group_hht_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="hht_device_rule_operator" model="ir.rule">
        <field name="name">HHT Device: Operator sees own</field>
        <field name="model_id" ref="model_hht_device"/>
        <field name="groups" eval="[(4, ref('group_hht_operator'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hht_device_rule_admin" model="ir.rule">
        <field name="name">HHT Device: Admin sees all</field>
        <field name="model_id" ref="model_hht_device"/>
        <field name="groups" eval="[(4, ref('group_hht_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="hht_sync_queue_rule_operator" model="ir.rule">
        <field name="name">HHT Sync Queue: Operator sees own device</field>
        <field name="model_id" ref="model_hht_sync_queue"/>
        <field name="groups" eval="[(4, ref('group_hht_operator'))]"/>
        <field name="domain_force">[('device_id.user_id', '=', user.id)]</field>
    </record>

    <record id="hht_sync_queue_rule_admin" model="ir.rule">
        <field name="name">HHT Sync Queue: Admin sees all</field>
        <field name="model_id" ref="model_hht_sync_queue"/>
        <field name="groups" eval="[(4, ref('group_hht_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>
