<odoo>

    <record id="view_hht_regenerate_secret_wizard_form" model="ir.ui.view">
        <field name="name">hht.regenerate.secret.wizard.form</field>
        <field name="model">hht.regenerate.secret.wizard</field>
        <field name="arch" type="xml">
            <form string="Rotate Device Secret">
                <group>
                    <field name="device_id" readonly="1"/>
                    <field name="confirm"/>
                    <field name="new_secret_preview"
                           readonly="1"
                           invisible="not new_secret_preview"/>
                </group>
                <footer>
                    <button name="action_rotate" type="object"
                            string="Rotate Now" class="btn-danger"
                            invisible="not confirm"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hht_regenerate_secret_wizard" model="ir.actions.act_window">
        <field name="name">Rotate Device Secret</field>
        <field name="res_model">hht.regenerate.secret.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hht_device"/>
    </record>

</odoo>
