<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_super_admin_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.super_admin</field>
        <field name="model">res.config.settings</field>
        <field name="priority">100</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Super Admin" string="Super Admin" name="custom_super_admin"
                     groups="custom_super_admin.group_super_admin">
                    <block title="Tenant Orchestrator">
                        <setting string="Orchestrator URL"
                                 help="Base URL of tenant-orchestrator service.">
                            <field name="custom_super_admin_orchestrator_url"/>
                        </setting>
                        <setting string="Grafana URL"
                                 help="Base URL used to build per-tenant dashboard links.">
                            <field name="custom_super_admin_grafana_base_url"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
