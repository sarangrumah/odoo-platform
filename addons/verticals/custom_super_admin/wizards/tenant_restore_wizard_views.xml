<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tenant_restore_wizard_form" model="ir.ui.view">
        <field name="name">tenant.restore.wizard.form</field>
        <field name="model">tenant.restore.wizard</field>
        <field name="arch" type="xml">
            <form string="Restore Backup">
                <sheet>
                    <group>
                        <field name="tenant_id" readonly="1"/>
                        <field name="slug" readonly="1"/>
                        <field name="backup_id"/>
                        <field name="s3_key" readonly="1"/>
                        <field name="target_db"/>
                        <field name="confirm_destructive"
                               invisible="target_db != tenant_id.db_name"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_restore" string="Restore" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
