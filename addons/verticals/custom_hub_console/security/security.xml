<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_hub" model="ir.module.category">
        <field name="name">Custom Platform / Hub</field>
        <field name="sequence">90</field>
    </record>

    <record id="group_hub_viewer" model="res.groups">
        <field name="name">Hub Viewer</field>
        <field name="category_id" ref="module_category_hub"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hub_csm" model="res.groups">
        <field name="name">Hub CSM</field>
        <field name="category_id" ref="module_category_hub"/>
        <field name="implied_ids" eval="[(4, ref('group_hub_viewer'))]"/>
    </record>

    <record id="group_hub_admin" model="res.groups">
        <field name="name">Hub Admin</field>
        <field name="category_id" ref="module_category_hub"/>
        <field name="implied_ids" eval="[(4, ref('group_hub_csm'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
