<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_landing_admin.MonitoringDashboard">
        <div class="o_landing_monitoring">
            <div class="o_landing_monitoring_header">
                <h3>Tenant Health Heatmap</h3>
            </div>

            <div t-if="state.loading" class="o_landing_loading">
                <i class="fa fa-spinner fa-spin"/> Loading…
            </div>

            <div t-else="" class="o_landing_heat_grid">
                <t t-foreach="state.tiles" t-as="tile" t-key="tile.id">
                    <div class="o_landing_heat_tile"
                         t-att-class="'tone-' + tile.klass"
                         t-on-click="() => this.openDrill(tile)">
                        <div class="o_landing_heat_name"
                             t-esc="tile.tenantName"/>
                        <div class="o_landing_heat_metrics">
                            <span>CPU <t t-esc="tile.cpu_pct || 0"/>%</span>
                            <span>MEM <t t-esc="tile.mem_pct || 0"/>%</span>
                            <span>DSK <t t-esc="tile.disk_pct || 0"/>%</span>
                        </div>
                    </div>
                </t>
            </div>

            <div t-if="state.drill" class="o_landing_modal_backdrop"
                 t-on-click="closeDrill">
                <div class="o_landing_modal" t-on-click.stop="">
                    <div class="o_landing_modal_header">
                        <h4 t-esc="state.drill.tenantName"/>
                        <button class="btn btn-link"
                                t-on-click="closeDrill">×</button>
                    </div>
                    <div class="o_landing_modal_body">
                        <dl class="o_landing_kv">
                            <dt>Status</dt><dd t-esc="state.drill.status"/>
                            <dt>CPU</dt><dd><t t-esc="state.drill.cpu_pct || 0"/>%</dd>
                            <dt>MEM</dt><dd><t t-esc="state.drill.mem_pct || 0"/>%</dd>
                            <dt>DSK</dt><dd><t t-esc="state.drill.disk_pct || 0"/>%</dd>
                            <dt>Last check</dt><dd t-esc="state.drill.last_check || '—'"/>
                        </dl>
                        <div t-if="state.drill.grafanaUrl" class="mt-3">
                            <iframe t-att-src="state.drill.grafanaUrl"
                                    class="o_landing_grafana_iframe"/>
                        </div>
                        <div t-else="" class="o_landing_chart_placeholder">
                            <i class="fa fa-line-chart fa-2x"/>
                            <div>Time-series chart placeholder</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
