<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_landing_admin.VpsConsole">
        <div class="o_landing_vps">
            <div class="o_landing_vps_toolbar">
                <h3>VPS</h3>
                <div class="spacer"/>
                <button class="btn btn-primary btn-sm"
                        t-on-click="onRegister"
                        t-att-disabled="state.actionBusy">
                    <i class="fa fa-plus"/> Register
                </button>
            </div>

            <div t-if="state.loading" class="o_landing_loading">
                <i class="fa fa-spinner fa-spin"/> Loading VPS…
            </div>

            <table t-else="" class="table o_landing_vps_table">
                <thead><tr>
                    <th>Name</th><th>State</th><th>IP</th>
                    <th>Region</th><th>Provider</th><th/>
                </tr></thead>
                <tbody>
                    <t t-foreach="state.vpsList" t-as="v" t-key="v.id">
                        <tr>
                            <td t-esc="v.name"/>
                            <td>
                                <span class="o_landing_chip"
                                      t-att-class="'state-' + v.state"
                                      t-esc="v.state"/>
                            </td>
                            <td t-esc="v.ip_address || '—'"/>
                            <td t-esc="v.region || '—'"/>
                            <td t-esc="v.provider || '—'"/>
                            <td>
                                <button class="btn btn-link btn-sm"
                                        t-on-click="() => this.openDetail(v)">
                                    Open
                                </button>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div t-if="state.detail" class="o_landing_modal_backdrop"
                 t-on-click="closeDetail">
                <div class="o_landing_modal"
                     t-on-click.stop="">
                    <div class="o_landing_modal_header">
                        <h4 t-esc="state.detail.name"/>
                        <button class="btn btn-link"
                                t-on-click="closeDetail">×</button>
                    </div>

                    <div class="o_landing_modal_body">
                        <div t-if="state.actionError" class="alert alert-danger"
                             t-esc="state.actionError"/>

                        <section>
                            <h5>Info</h5>
                            <dl class="o_landing_kv">
                                <dt>State</dt>
                                <dd t-esc="state.detail.state"/>
                                <dt>IP</dt>
                                <dd t-esc="state.detail.ip_address || '—'"/>
                                <dt>Region</dt>
                                <dd t-esc="state.detail.region || '—'"/>
                                <dt>Provider</dt>
                                <dd t-esc="state.detail.provider || '—'"/>
                            </dl>
                        </section>

                        <section>
                            <h5>Environment</h5>
                            <table class="table table-sm">
                                <thead><tr>
                                    <th>Key</th><th>Value</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.envs" t-as="e" t-key="e.id">
                                        <tr>
                                            <td t-esc="e.key"/>
                                            <td t-if="e.is_secret">••••••</td>
                                            <td t-else="" t-esc="e.value"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </section>

                        <section>
                            <h5>Bootstrap log</h5>
                            <pre class="o_landing_log"
                                 t-esc="state.logTail || '(no output yet)'"/>
                        </section>

                        <section>
                            <h5>Grafana</h5>
                            <div t-if="state.grafanaUrl">
                                <iframe t-att-src="state.grafanaUrl"
                                        class="o_landing_grafana_iframe"/>
                            </div>
                            <div t-else="" class="text-muted">
                                No Grafana dashboard configured.
                            </div>
                        </section>
                    </div>

                    <div class="o_landing_modal_footer">
                        <button class="btn btn-secondary"
                                t-att-disabled="state.actionBusy"
                                t-on-click="onBootstrap">Bootstrap</button>
                        <button class="btn btn-secondary"
                                t-att-disabled="state.actionBusy"
                                t-on-click="onDeployStack">Deploy Stack</button>
                        <button class="btn btn-secondary"
                                t-att-disabled="state.actionBusy"
                                t-on-click="onSyncAddons">Sync Addons</button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
