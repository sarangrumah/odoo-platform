<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_landing_admin.JourneyWorkspace">
        <div class="o_landing_journey">
            <div class="o_landing_journey_header">
                <button class="btn btn-link" t-on-click="onBack">
                    <i class="fa fa-arrow-left"/> Pipeline
                </button>
                <h2 t-if="state.journey" t-esc="state.journey.name"/>
                <span t-if="state.journey" class="o_landing_chip"
                      t-esc="state.journey.stage"/>
            </div>

            <div t-if="state.loading" class="o_landing_loading">
                <i class="fa fa-spinner fa-spin"/> Loading journey…
            </div>

            <div t-elif="!state.journey" class="o_landing_notfound">
                Journey not found.
            </div>

            <div t-else="" class="o_landing_journey_body">
                <aside class="o_landing_journey_side">
                    <div class="o_landing_side_block">
                        <div class="o_landing_side_label">Tenant</div>
                        <div t-esc="state.journey.tenant_name || '—'"/>
                    </div>
                    <div class="o_landing_side_block">
                        <div class="o_landing_side_label">Vertical</div>
                        <div t-esc="state.journey.vertical || '—'"/>
                    </div>
                    <div class="o_landing_side_block">
                        <div class="o_landing_side_label">Due</div>
                        <div t-esc="state.journey.due_date || '—'"/>
                    </div>
                    <div class="o_landing_side_block">
                        <div class="o_landing_side_label">Priority</div>
                        <div t-esc="state.journey.priority || '—'"/>
                    </div>
                    <div class="o_landing_side_links">
                        <a href="#" t-on-click.prevent="() => this.selectTab('vps')">
                            <i class="fa fa-server"/> VPS
                        </a>
                        <a href="#" t-on-click.prevent="() => this.selectTab('modules')">
                            <i class="fa fa-puzzle-piece"/> Modules
                        </a>
                        <a href="#" t-on-click.prevent="() => this.selectTab('tasks')">
                            <i class="fa fa-tasks"/> Tasks
                        </a>
                    </div>
                </aside>

                <section class="o_landing_journey_main">
                    <nav class="o_landing_tabs">
                        <t t-foreach="tabs" t-as="tab" t-key="tab.key">
                            <button
                                t-att-class="state.activeTab === tab.key ? 'active' : ''"
                                t-on-click="() => this.selectTab(tab.key)">
                                <t t-esc="tab.label"/>
                            </button>
                        </t>
                    </nav>

                    <div class="o_landing_tab_body">
                        <t t-if="state.activeTab === 'brd'">
                            <BrdUpload journeyId="state.journey.id"
                                       onUploaded="() => this.onBrdUploaded()"/>
                            <h4 class="mt-3">Documents</h4>
                            <table class="table">
                                <thead><tr>
                                    <th>Name</th><th>State</th><th>Uploaded</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.brds" t-as="b" t-key="b.id">
                                        <tr>
                                            <td t-esc="b.name"/>
                                            <td t-esc="b.state"/>
                                            <td t-esc="b.uploaded_on || '—'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'recommendations'">
                            <table class="table">
                                <thead><tr>
                                    <th>Title</th><th>Module</th>
                                    <th>Score</th><th>Rationale</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.recommendations" t-as="r" t-key="r.id">
                                        <tr>
                                            <td t-esc="r.title"/>
                                            <td t-esc="r.module_id and r.module_id[1] || '—'"/>
                                            <td t-esc="r.score"/>
                                            <td t-esc="r.rationale"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'vps'">
                            <table class="table">
                                <thead><tr>
                                    <th>Name</th><th>State</th><th>IP</th><th>Region</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.vpsList" t-as="v" t-key="v.id">
                                        <tr>
                                            <td t-esc="v.name"/>
                                            <td t-esc="v.state"/>
                                            <td t-esc="v.ip_address || '—'"/>
                                            <td t-esc="v.region || '—'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'modules'">
                            <table class="table">
                                <thead><tr>
                                    <th>Module</th><th>State</th>
                                    <th>Canary</th><th>Deployed</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.modules" t-as="m" t-key="m.id">
                                        <tr>
                                            <td t-esc="m.module_id and m.module_id[1] || '—'"/>
                                            <td t-esc="m.state"/>
                                            <td t-esc="m.canary ? 'yes' : 'no'"/>
                                            <td t-esc="m.deployed_on || '—'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'devcycles'">
                            <table class="table">
                                <thead><tr>
                                    <th>Name</th><th>State</th>
                                    <th>Start</th><th>End</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.devCycles" t-as="c" t-key="c.id">
                                        <tr>
                                            <td t-esc="c.name"/>
                                            <td t-esc="c.state"/>
                                            <td t-esc="c.start_date || '—'"/>
                                            <td t-esc="c.end_date || '—'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'tasks'">
                            <table class="table">
                                <thead><tr>
                                    <th>Task</th><th>Stage</th><th>Deadline</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.tasks" t-as="t" t-key="t.id">
                                        <tr>
                                            <td t-esc="t.name"/>
                                            <td t-esc="t.stage_id and t.stage_id[1] || '—'"/>
                                            <td t-esc="t.date_deadline || '—'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-elif="state.activeTab === 'activity'">
                            <ul class="o_landing_activity">
                                <t t-foreach="state.activity" t-as="a" t-key="a.id">
                                    <li>
                                        <div class="o_landing_act_meta">
                                            <span t-esc="a.author_id and a.author_id[1] || 'system'"/>
                                            <span t-esc="a.date"/>
                                        </div>
                                        <div t-if="a.subject"
                                             class="o_landing_act_subject"
                                             t-esc="a.subject"/>
                                        <div class="o_landing_act_body"
                                             t-out="a.body"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>
                </section>
            </div>
        </div>
    </t>
</templates>
