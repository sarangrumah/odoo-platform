<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_landing_admin.ModuleDeployConsole">
        <div class="o_landing_modules">
            <div class="o_landing_modules_header">
                <h3>Module Catalog</h3>
            </div>

            <div t-if="state.loading" class="o_landing_loading">
                <i class="fa fa-spinner fa-spin"/> Loading…
            </div>

            <table t-else="" class="table">
                <thead><tr>
                    <th>Module</th><th>Technical</th><th>Version</th>
                    <th>Maturity</th><th>Category</th><th/>
                </tr></thead>
                <tbody>
                    <t t-foreach="state.modules" t-as="m" t-key="m.id">
                        <tr>
                            <td t-esc="m.display_name"/>
                            <td><code t-esc="m.technical_name"/></td>
                            <td t-esc="m.version || '—'"/>
                            <td>
                                <span class="o_landing_chip"
                                      t-att-class="'maturity-' + m.maturity"
                                      t-esc="m.maturity"/>
                            </td>
                            <td t-esc="m.category || '—'"/>
                            <td>
                                <button class="btn btn-primary btn-sm"
                                        t-on-click="() => this.openWizard(m)">
                                    Deploy
                                </button>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div t-if="state.wizardOpen" class="o_landing_modal_backdrop"
                 t-on-click="closeWizard">
                <div class="o_landing_modal" t-on-click.stop="">
                    <div class="o_landing_modal_header">
                        <h4>
                            Deploy
                            <code t-esc="state.wizardModule and state.wizardModule.technical_name"/>
                        </h4>
                        <button class="btn btn-link"
                                t-on-click="closeWizard">×</button>
                    </div>
                    <div class="o_landing_modal_body">
                        <div t-if="state.wizardError" class="alert alert-danger"
                             t-esc="state.wizardError"/>
                        <div t-if="state.wizardOk" class="alert alert-success"
                             t-esc="state.wizardOk"/>

                        <div class="mb-2">
                            <label>Target tenant</label>
                            <select class="form-control"
                                    t-on-change="onChangeTenant">
                                <option value="">— pick a tenant —</option>
                                <t t-foreach="state.tenants" t-as="t" t-key="t.id">
                                    <option t-att-value="t.id"
                                            t-esc="t.name"/>
                                </t>
                            </select>
                        </div>

                        <div class="form-check">
                            <input type="checkbox" class="form-check-input"
                                   id="landing_canary_toggle"
                                   t-att-checked="state.canary"
                                   t-on-change="onToggleCanary"/>
                            <label for="landing_canary_toggle"
                                   class="form-check-label">
                                Canary deploy (1 worker first, then full
                                roll-out on success).
                            </label>
                        </div>
                    </div>
                    <div class="o_landing_modal_footer">
                        <button class="btn btn-secondary"
                                t-on-click="closeWizard">Cancel</button>
                        <button class="btn btn-primary"
                                t-att-disabled="state.wizardBusy"
                                t-on-click="submitDeploy">
                            Queue deploy
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
