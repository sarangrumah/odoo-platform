<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="custom_landing_admin.OnboardingPipeline">
        <div class="o_landing_pipeline">
            <div class="o_landing_pipeline_toolbar">
                <form class="o_landing_search" t-on-submit="onSearchSubmit">
                    <input type="search" placeholder="Search journey…"
                           t-att-value="state.search"
                           t-on-input="onSearchInput"/>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa fa-search"/>
                    </button>
                </form>
                <div class="o_landing_filters">
                    <label>BA</label>
                    <input type="number" placeholder="user id"
                           t-att-value="state.filterBa"
                           t-on-change="onChangeBa"/>
                    <label>Vertical</label>
                    <input type="text" placeholder="ppob, residensia…"
                           t-att-value="state.filterVertical"
                           t-on-change="onChangeVertical"/>
                </div>
            </div>

            <div t-if="state.loading" class="o_landing_loading">
                <i class="fa fa-spinner fa-spin"/> Loading pipeline…
            </div>

            <div t-else="" class="o_landing_kanban">
                <t t-foreach="state.stages" t-as="stage" t-key="stage.key">
                    <div class="o_landing_col"
                         t-on-dragover="(ev) => this.onDragOver(ev)"
                         t-on-drop="(ev) => this.onDrop(ev, stage.key)">
                        <div class="o_landing_col_header">
                            <span t-esc="stage.label"/>
                            <span class="o_landing_col_count"
                                  t-esc="(state.journeysByStage[stage.key] || []).length"/>
                        </div>
                        <div class="o_landing_col_body">
                            <t t-foreach="state.journeysByStage[stage.key] || []"
                               t-as="j" t-key="j.id">
                                <div class="o_landing_card"
                                     draggable="true"
                                     t-on-dragstart="(ev) => this.onDragStart(ev, j.id, stage.key)"
                                     t-on-click="() => this.onClickCard(j)">
                                    <div class="o_landing_card_title"
                                         t-esc="j.name"/>
                                    <div class="o_landing_card_sub">
                                        <span t-esc="j.tenant_name || '—'"/>
                                        <span class="o_landing_chip"
                                              t-esc="j.vertical || '—'"/>
                                    </div>
                                    <div class="o_landing_card_foot">
                                        <span t-if="j.due_date">
                                            <i class="fa fa-calendar"/>
                                            <t t-esc="j.due_date"/>
                                        </span>
                                        <span t-if="j.priority">
                                            <i class="fa fa-star"/>
                                            <t t-esc="j.priority"/>
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
