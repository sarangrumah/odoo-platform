<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Stub action: list partners that already carry a tag from
            this vertical. Replace with vertical-specific model when
            forking.
        -->
        <record id="action_tagged_partners" model="ir.actions.act_window">
            <field name="name">Tagged Partners</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('x_custom_vertical_example_tag', '!=', False)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No partners are tagged yet.
                </p>
                <p>
                    Open any contact and set the
                    <b>Vertical Example Tag</b> field on the Vertical tab.
                </p>
            </field>
        </record>

        <!--
            Top-level menu attached to custom_core.menu_custom_root so it
            sits alongside other Custom verticals in the navbar.
        -->
        <menuitem
            id="menu_root"
            name="Vertical Example"
            parent="custom_core.menu_custom_root"
            sequence="50"
            groups="custom_vertical_example.group_user"/>

        <menuitem
            id="menu_tagged_partners"
            name="Tagged Partners"
            parent="menu_root"
            action="action_tagged_partners"
            sequence="10"/>

    </data>
</odoo>
