<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tenant_infra_user" model="res.groups">
            <field name="name">Tenant Infra User</field>
            <field name="comment">Read-only access to VPS fleet + environments.</field>
        </record>

        <record id="group_tenant_infra_manager" model="res.groups">
            <field name="name">Tenant Infra Manager</field>
            <field name="implied_ids" eval="[Command.link(ref('group_tenant_infra_user'))]"/>
            <field name="comment">Full lifecycle control of VPS + environments + bootstrap templates.</field>
        </record>

        <!-- Inherit Super Admin into Tenant Infra Manager so existing ops keep their reach -->
        <record id="custom_super_admin.group_super_admin" model="res.groups">
            <field name="implied_ids" eval="[Command.link(ref('custom_tenant_infra.group_tenant_infra_manager'))]"/>
        </record>

    </data>
</odoo>
