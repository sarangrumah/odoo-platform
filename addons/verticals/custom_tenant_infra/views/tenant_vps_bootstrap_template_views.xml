<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tenant_vps_bootstrap_template_list" model="ir.ui.view">
        <field name="name">tenant.vps.bootstrap.template.list</field>
        <field name="model">tenant.vps.bootstrap.template</field>
        <field name="arch" type="xml">
            <list string="Bootstrap Templates">
                <field name="name"/>
                <field name="script_kind"/>
                <field name="version"/>
                <field name="script_attachment_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tenant_vps_bootstrap_template_form" model="ir.ui.view">
        <field name="name">tenant.vps.bootstrap.template.form</field>
        <field name="model">tenant.vps.bootstrap.template</field>
        <field name="arch" type="xml">
            <form string="Bootstrap Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="script_kind"/>
                            <field name="version"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="script_attachment_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Variables (defaults)">
                            <field name="variables_json" widget="text"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tenant_vps_bootstrap_template" model="ir.actions.act_window">
        <field name="name">Bootstrap Templates</field>
        <field name="res_model">tenant.vps.bootstrap.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
