<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_onboarding_go_no_go_wizard_form" model="ir.ui.view">
        <field name="name">onboarding.go.no.go.wizard.form</field>
        <field name="model">onboarding.go.no.go.wizard</field>
        <field name="arch" type="xml">
            <form string="Go / No-Go">
                <sheet>
                    <group>
                        <field name="journey_id" readonly="1"/>
                        <field name="decision" widget="radio"/>
                        <field name="rejection_reason" invisible="decision != 'no_go'"
                               required="decision == 'no_go'"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_decide" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
