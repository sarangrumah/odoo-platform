<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_onboarding_brd_upload_wizard_form" model="ir.ui.view">
        <field name="name">onboarding.brd.upload.wizard.form</field>
        <field name="model">onboarding.brd.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload BRDs">
                <sheet>
                    <group>
                        <field name="journey_id" readonly="1"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_upload" type="object" string="Upload &amp; Analyze" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
