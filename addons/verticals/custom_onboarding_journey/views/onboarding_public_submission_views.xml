<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_onboarding_public_submission_list" model="ir.ui.view">
        <field name="name">onboarding.public.submission.list</field>
        <field name="model">onboarding.public.submission</field>
        <field name="arch" type="xml">
            <list decoration-muted="status=='rejected'" decoration-success="status=='promoted'">
                <field name="submitted_at"/>
                <field name="name"/>
                <field name="status"/>
                <field name="journey_id"/>
            </list>
        </field>
    </record>

    <record id="view_onboarding_public_submission_form" model="ir.ui.view">
        <field name="name">onboarding.public.submission.form</field>
        <field name="model">onboarding.public.submission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_promote_to_journey" type="object"
                            string="Promote to Journey" class="btn-primary"
                            invisible="status == 'promoted'"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="status != 'submitted'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="submitted_at"/>
                        <field name="source_ip_hash"/>
                        <field name="public_token"/>
                        <field name="journey_id"/>
                    </group>
                    <separator string="Raw Payload"/>
                    <field name="raw_payload_json" widget="text"/>
                    <field name="rejection_reason" placeholder="Reason if rejected..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_onboarding_public_submission" model="ir.actions.act_window">
        <field name="name">Public Inbox</field>
        <field name="res_model">onboarding.public.submission</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
