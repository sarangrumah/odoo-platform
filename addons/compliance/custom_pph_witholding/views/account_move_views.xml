<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_form_witholding_button" model="ir.ui.view">
        <field name="name">account.move.form.witholding.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button string="Apply Witholding"
                        name="action_open_witholding_wizard"
                        type="object"
                        groups="custom_pph_witholding.group_witholding_user"/>
            </xpath>
        </field>
    </record>

</odoo>
