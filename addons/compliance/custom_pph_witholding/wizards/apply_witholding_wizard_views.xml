<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_apply_witholding_wizard_form" model="ir.ui.view">
        <field name="name">custom.apply.witholding.wizard.form</field>
        <field name="model">custom.apply.witholding.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply Witholding">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="pph_type"/>
                        <field name="service_category"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="amount"/>
                        <field name="source_move_id" invisible="1"/>
                    </group>
                </group>
                <group string="Preview" invisible="not preview_rule_id and not preview_rate">
                    <field name="preview_rule_id" readonly="1"/>
                    <field name="preview_rate" readonly="1"/>
                    <field name="preview_withheld" readonly="1"/>
                    <field name="preview_remain" readonly="1"/>
                    <field name="preview_has_npwp" readonly="1"/>
                </group>
                <footer>
                    <button name="action_preview" type="object"
                            string="Preview" class="btn-secondary"/>
                    <button name="action_apply" type="object"
                            string="Apply" class="btn-primary"/>
                    <button special="cancel" string="Close"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
