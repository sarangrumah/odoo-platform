<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ir_model_fields_form_pdp" model="ir.ui.view">
        <field name="name">ir.model.fields.form.pdp</field>
        <field name="model">ir.model.fields</field>
        <field name="inherit_id" ref="base.view_model_fields_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="PDP Classification">
                    <field name="x_pdp_classification_id"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_ir_model_fields_search_pdp" model="ir.ui.view">
        <field name="name">ir.model.fields.search.pdp</field>
        <field name="model">ir.model.fields</field>
        <field name="inherit_id" ref="base.view_model_fields_search"/>
        <field name="arch" type="xml">
            <field name="model_id" position="after">
                <field name="x_pdp_classification_id"/>
                <filter string="PII Tagged" name="pii_tagged" domain="[('x_pdp_classification_id','!=',False)]"/>
            </field>
        </field>
    </record>
</odoo>
