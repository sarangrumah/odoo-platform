<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pdp_classification_list" model="ir.ui.view">
        <field name="name">pdp.classification.list</field>
        <field name="model">pdp.classification</field>
        <field name="arch" type="xml">
            <list string="PDP Classifications">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="requires_consent"/>
                <field name="requires_masking"/>
                <field name="default_retention_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pdp_classification_form" model="ir.ui.view">
        <field name="name">pdp.classification.form</field>
        <field name="model">pdp.classification</field>
        <field name="arch" type="xml">
            <form string="PDP Classification">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="requires_consent"/>
                            <field name="requires_masking"/>
                            <field name="default_retention_days"/>
                            <field name="color"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pdp_classification_search" model="ir.ui.view">
        <field name="name">pdp.classification.search</field>
        <field name="model">pdp.classification</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <filter string="Requires Consent" name="req_consent" domain="[('requires_consent','=',True)]"/>
                <filter string="Requires Masking" name="req_masking" domain="[('requires_masking','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="action_pdp_classification" model="ir.actions.act_window">
        <field name="name">PDP Classifications</field>
        <field name="res_model">pdp.classification</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
