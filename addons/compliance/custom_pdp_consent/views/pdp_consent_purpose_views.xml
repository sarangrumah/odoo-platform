<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pdp_consent_purpose_list" model="ir.ui.view">
        <field name="name">pdp.consent.purpose.list</field>
        <field name="model">pdp.consent.purpose</field>
        <field name="arch" type="xml">
            <list string="Consent Purposes">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="requires_renewal_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pdp_consent_purpose_form" model="ir.ui.view">
        <field name="name">pdp.consent.purpose.form</field>
        <field name="model">pdp.consent.purpose</field>
        <field name="arch" type="xml">
            <form string="Consent Purpose">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="requires_renewal_days"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pdp_consent_purpose" model="ir.actions.act_window">
        <field name="name">Consent Purposes</field>
        <field name="res_model">pdp.consent.purpose</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
