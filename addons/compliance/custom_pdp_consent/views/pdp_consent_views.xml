<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pdp_consent_list" model="ir.ui.view">
        <field name="name">pdp.consent.list</field>
        <field name="model">pdp.consent</field>
        <field name="arch" type="xml">
            <list string="Consents" decoration-success="state=='active'" decoration-muted="state=='withdrawn'" decoration-warning="state=='expired'">
                <field name="partner_id"/>
                <field name="purpose_id"/>
                <field name="given_at"/>
                <field name="expires_at"/>
                <field name="withdrawn_at"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pdp_consent_form" model="ir.ui.view">
        <field name="name">pdp.consent.form</field>
        <field name="model">pdp.consent</field>
        <field name="arch" type="xml">
            <form string="Consent">
                <header>
                    <button name="action_withdraw" type="object" string="Withdraw" class="btn-warning"
                            invisible="state == 'withdrawn'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,expired,withdrawn"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="purpose_id"/>
                            <field name="version"/>
                        </group>
                        <group>
                            <field name="given_at"/>
                            <field name="expires_at"/>
                            <field name="withdrawn_at"/>
                        </group>
                    </group>
                    <group string="Evidence">
                        <field name="evidence" filename="evidence_filename"/>
                        <field name="evidence_filename" invisible="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pdp_consent_search" model="ir.ui.view">
        <field name="name">pdp.consent.search</field>
        <field name="model">pdp.consent</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="purpose_id"/>
                <filter string="Active" name="f_active" domain="[('state','=','active')]"/>
                <filter string="Expired" name="f_expired" domain="[('state','=','expired')]"/>
                <filter string="Withdrawn" name="f_withdrawn" domain="[('state','=','withdrawn')]"/>
                <separator/>
                    <filter string="Purpose" name="g_purpose" context="{'group_by':'purpose_id'}"/>
                    <filter string="State" name="g_state" context="{'group_by':'state'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_pdp_consent" model="ir.actions.act_window">
        <field name="name">Consents</field>
        <field name="res_model">pdp.consent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
