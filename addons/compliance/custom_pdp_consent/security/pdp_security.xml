<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_consent_manager" model="res.groups">
            <field name="name">PDP / Consent Manager</field>
            <field name="privilege_id" ref="custom_core.res_groups_privilege_custom_platform"/>
            <field name="implied_ids" eval="[(4, ref('custom_core.group_custom_user'))]"/>
        </record>

        <record id="rule_pdp_consent_portal" model="ir.rule">
            <field name="name">Portal: own consents only</field>
            <field name="model_id" ref="model_pdp_consent"/>
            <field name="domain_force">[('partner_id','=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
