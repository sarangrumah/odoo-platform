<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_user" model="res.groups">
            <field name="name">Coretax / User</field>
            <field name="privilege_id" ref="custom_core.res_groups_privilege_custom_platform"/>
            <field name="implied_ids" eval="[(4, ref('custom_core.group_custom_user'))]"/>
            <field name="comment">Can manage Bukti Potong records, generate/import XML, view Coretax config (read-only).</field>
        </record>

        <record id="group_admin" model="res.groups">
            <field name="name">Coretax / Administrator</field>
            <field name="privilege_id" ref="custom_core.res_groups_privilege_custom_platform"/>
            <field name="implied_ids" eval="[(4, ref('group_user')), (4, ref('custom_core.group_custom_admin'))]"/>
            <field name="comment">Can edit Coretax configuration and upload Sertifikat Elektronik (.p12).</field>
        </record>

    </data>
</odoo>
