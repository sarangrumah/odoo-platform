<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_coretax_import_wizard_form" model="ir.ui.view">
        <field name="name">custom.coretax.import.wizard.form</field>
        <field name="model">custom.coretax.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Coretax XML Import">
                <sheet>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="source"/>
                        </group>
                        <group>
                            <field name="xml_file" filename="xml_filename"/>
                            <field name="xml_filename" invisible="1"/>
                        </group>
                    </group>
                    <group invisible="not log">
                        <field name="created_count" readonly="1"/>
                        <field name="skipped_count" readonly="1"/>
                        <field name="log" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_coretax_import_wizard" model="ir.actions.act_window">
        <field name="name">Import XML</field>
        <field name="res_model">custom.coretax.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
