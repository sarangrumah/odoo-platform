<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_coretax_sertel_upload_wizard_form" model="ir.ui.view">
        <field name="name">custom.coretax.sertel.upload.wizard.form</field>
        <field name="model">custom.coretax.sertel.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Sertifikat Elektronik (.p12)">
                <sheet>
                    <group>
                        <field name="config_id"/>
                        <field name="p12_data" filename="p12_filename"/>
                        <field name="p12_filename" invisible="1"/>
                        <field name="p12_password" password="True"/>
                        <field name="sertel_expiry"/>
                    </group>
                    <group invisible="not result_message">
                        <field name="result_message" readonly="1"/>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        The .p12 password is used only to validate the certificate
                        on upload and is never stored. The certificate body is
                        encrypted at rest with the env-keyed Fernet master key.
                        Every access is recorded in pdp.audit_log as
                        <code>sertel_access</code>.
                    </div>
                </sheet>
                <footer>
                    <button name="action_store" type="object"
                            string="Store Encrypted" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_coretax_sertel_upload_wizard" model="ir.actions.act_window">
        <field name="name">Upload Sertel</field>
        <field name="res_model">custom.coretax.sertel.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
