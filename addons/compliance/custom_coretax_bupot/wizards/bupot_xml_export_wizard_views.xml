<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bupot_xml_export_wizard_form" model="ir.ui.view">
        <field name="name">custom.bupot.xml.export.wizard.form</field>
        <field name="model">custom.bupot.xml.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Bukti Potong XML">
                <group>
                    <field name="bupot_id" readonly="1"/>
                </group>
                <group invisible="not output_file">
                    <field name="output_file" filename="output_file_name" readonly="1"/>
                    <field name="output_file_name" invisible="1"/>
                    <field name="attachment_id" readonly="1"/>
                </group>
                <footer>
                    <button name="action_generate" type="object"
                            string="Generate XML" class="btn-primary"/>
                    <button special="cancel" string="Close"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
