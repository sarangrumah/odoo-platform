<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Default numbering for Bupot Unifikasi lines.
        Referenced by `bupot_unifikasi_line.no_bupot` default
        (env['ir.sequence'].next_by_code("custom.bupot.unifikasi.line")).
    -->
    <record id="seq_bupot_unifikasi_line" model="ir.sequence">
        <field name="name">Bupot Unifikasi — Nomor Bukti Potong</field>
        <field name="code">custom.bupot.unifikasi.line</field>
        <field name="prefix">BUP/%(year)s/%(month)s/</field>
        <field name="padding">8</field>
        <field name="number_increment">1</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
