<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="custom_ops_monitor.HealthDashboard">
    <div class="o_ops_health_dashboard">
        <div class="o_ops_header">
            <h2>Tenant Health</h2>
            <small t-if="state.loading">Loading...</small>
            <small class="text-danger" t-if="state.error" t-esc="state.error"/>
        </div>

        <div class="o_ops_heatmap">
            <t t-foreach="state.tiles" t-as="tile" t-key="tile.id">
                <div t-att-class="tileClass(tile)"
                     t-on-click="() =&gt; this.onTileClick(tile)">
                    <div class="o_health_tile_name">
                        <t t-esc="tile.tenant_id[1]"/>
                    </div>
                    <div class="o_health_tile_score">
                        <t t-esc="tile.health_score"/>
                    </div>
                    <div class="o_health_tile_metrics">
                        <span>CPU <t t-esc="Math.round(tile.cpu_pct)"/>%</span>
                        <span>MEM <t t-esc="Math.round(tile.memory_pct)"/>%</span>
                        <span>DSK <t t-esc="Math.round(tile.disk_pct)"/>%</span>
                    </div>
                    <div class="o_health_tile_backup">
                        backup: <t t-esc="tile.backup_status"/>
                    </div>
                </div>
            </t>
        </div>

        <div t-if="state.selectedTenantId" class="o_ops_detail_panel">
            <div class="o_ops_detail_header">
                <h3>Detail (last 24h)</h3>
                <button class="btn btn-sm btn-secondary"
                        t-on-click="() =&gt; this.closeDetail()">Close</button>
            </div>
            <div class="o_ops_sparklines">
                <div>
                    <label>CPU %</label>
                    <svg width="300" height="60" class="o_ops_spark">
                        <path t-att-d="sparklinePath('cpu_pct')"
                              fill="none" stroke="#3b82f6" stroke-width="2"/>
                    </svg>
                </div>
                <div>
                    <label>Memory %</label>
                    <svg width="300" height="60" class="o_ops_spark">
                        <path t-att-d="sparklinePath('memory_pct')"
                              fill="none" stroke="#10b981" stroke-width="2"/>
                    </svg>
                </div>
                <div>
                    <label>Disk %</label>
                    <svg width="300" height="60" class="o_ops_spark">
                        <path t-att-d="sparklinePath('disk_pct')"
                              fill="none" stroke="#f59e0b" stroke-width="2"/>
                    </svg>
                </div>
            </div>
            <div t-if="state.grafanaUrl" class="o_ops_grafana">
                <iframe t-att-src="state.grafanaUrl"
                        width="100%" height="500" frameborder="0"/>
            </div>
        </div>
    </div>
</t>

</templates>
