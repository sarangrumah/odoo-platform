<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_ops_monitor" model="ir.module.category">
            <field name="name">Operations Monitor</field>
            <field name="sequence">90</field>
        </record>

        <record id="group_ops_viewer" model="res.groups">
            <field name="name">Ops Viewer</field>
            <field name="category_id" ref="module_category_ops_monitor"/>
            <field name="comment">Read-only access to health, forecasts, incidents.</field>
        </record>

        <record id="group_ops_engineer" model="res.groups">
            <field name="name">Ops Engineer</field>
            <field name="category_id" ref="module_category_ops_monitor"/>
            <field name="implied_ids" eval="[Command.link(ref('group_ops_viewer'))]"/>
            <field name="comment">Acknowledge / resolve incidents.</field>
        </record>

        <record id="group_ops_admin" model="res.groups">
            <field name="name">Ops Admin</field>
            <field name="category_id" ref="module_category_ops_monitor"/>
            <field name="implied_ids" eval="[Command.link(ref('group_ops_engineer'))]"/>
            <field name="comment">Configure thresholds, prometheus URL, predictor.</field>
        </record>
    </data>
</odoo>
