<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ops_incident_list" model="ir.ui.view">
        <field name="name">custom.ops.incident.list</field>
        <field name="model">custom.ops.incident</field>
        <field name="arch" type="xml">
            <list decoration-danger="severity in ('critical','page')"
                  decoration-warning="severity == 'warning'"
                  decoration-muted="state == 'resolved'">
                <field name="fired_at"/>
                <field name="tenant_id"/>
                <field name="alert_name"/>
                <field name="severity" widget="badge"/>
                <field name="summary"/>
                <field name="state" widget="badge"/>
                <field name="assigned_user_id"/>
            </list>
        </field>
    </record>

    <record id="view_ops_incident_form" model="ir.ui.view">
        <field name="name">custom.ops.incident.form</field>
        <field name="model">custom.ops.incident</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_acknowledge" string="Acknowledge"
                            type="object" class="btn-primary"
                            invisible="state != 'firing'"
                            groups="custom_ops_monitor.group_ops_engineer"/>
                    <button name="action_resolve" string="Resolve"
                            type="object" class="btn-success"
                            invisible="state == 'resolved'"
                            groups="custom_ops_monitor.group_ops_engineer"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="alert_name"/>
                            <field name="tenant_id"/>
                            <field name="severity"/>
                            <field name="assigned_user_id"/>
                        </group>
                        <group>
                            <field name="fired_at"/>
                            <field name="resolved_at"/>
                            <field name="fingerprint"/>
                            <field name="runbook_url" widget="url"/>
                        </group>
                    </group>
                    <group>
                        <field name="summary"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Raw Payload">
                            <field name="raw_payload"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ops_incident" model="ir.actions.act_window">
        <field name="name">Incidents</field>
        <field name="res_model">custom.ops.incident</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
