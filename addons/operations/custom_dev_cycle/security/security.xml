<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_dev_cycle_user" model="res.groups">
            <field name="name">Dev Cycle User</field>
            <field name="category_id" ref="base.module_category_services_project"/>
            <field name="comment">Read access to dev cycles, PRs and deployments.</field>
        </record>

        <record id="group_dev_cycle_manager" model="res.groups">
            <field name="name">Dev Cycle Manager</field>
            <field name="category_id" ref="base.module_category_services_project"/>
            <field name="implied_ids" eval="[Command.link(ref('group_dev_cycle_user'))]"/>
            <field name="comment">Full control over dev cycles, PRs and deployments.</field>
        </record>

    </data>
</odoo>
