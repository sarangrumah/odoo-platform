<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_brd_user" model="res.groups">
            <field name="name">BRD: User</field>
            <field name="comment">Upload BRDs and view own records.</field>
        </record>

        <record id="group_brd_analyst" model="res.groups">
            <field name="name">BRD: Analyst</field>
            <field name="implied_ids" eval="[(4, ref('group_brd_user'))]"/>
            <field name="comment">Run AI analysis and curate recommendations.</field>
        </record>

        <record id="group_brd_admin" model="res.groups">
            <field name="name">BRD: Admin</field>
            <field name="implied_ids" eval="[(4, ref('group_brd_analyst'))]"/>
            <field name="comment">Approve BRDs and manage the capability catalog.</field>
        </record>

        <!-- Row-level rule: a BRD User only sees their own documents. -->
        <record id="rule_brd_document_user_own" model="ir.rule">
            <field name="name">BRD Document: user sees own only</field>
            <field name="model_id" ref="model_brd_document"/>
            <field name="domain_force">[('owner_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_brd_user')])]"/>
        </record>

        <record id="rule_brd_document_analyst_all" model="ir.rule">
            <field name="name">BRD Document: analyst sees all</field>
            <field name="model_id" ref="model_brd_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_brd_analyst')])]"/>
        </record>

    </data>
</odoo>
