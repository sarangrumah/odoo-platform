<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_capability_entry_list" model="ir.ui.view">
            <field name="name">custom.module.capability.entry.list</field>
            <field name="model">custom.module.capability.entry</field>
            <field name="arch" type="xml">
                <list decoration-success="maturity == 'production'" decoration-warning="maturity == 'partial'" decoration-muted="maturity == 'scaffold'">
                    <field name="module_name"/>
                    <field name="category"/>
                    <field name="maturity"/>
                    <field name="version"/>
                    <field name="capability_tag_ids" widget="many2many_tags"/>
                    <field name="last_scanned"/>
                    <button name="action_rescan" type="object" string="Rescan All" class="btn-link" icon="fa-refresh"/>
                </list>
            </field>
        </record>

        <record id="view_capability_entry_form" model="ir.ui.view">
            <field name="name">custom.module.capability.entry.form</field>
            <field name="model">custom.module.capability.entry</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_rescan" type="object" string="Rescan Catalog" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="module_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="category"/>
                                <field name="maturity"/>
                                <field name="version"/>
                                <field name="last_scanned"/>
                            </group>
                            <group>
                                <field name="module_path"/>
                                <field name="capability_tag_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Summary">
                                <field name="summary" nolabel="1"/>
                            </page>
                            <page string="Models &amp; Routes">
                                <group>
                                    <field name="models_own" widget="json"/>
                                    <field name="models_inherit" widget="json"/>
                                    <field name="routes" widget="json"/>
                                    <field name="depends" widget="json"/>
                                </group>
                            </page>
                            <page string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_capability_entry_search" model="ir.ui.view">
            <field name="name">custom.module.capability.entry.search</field>
            <field name="model">custom.module.capability.entry</field>
            <field name="arch" type="xml">
                <search>
                    <field name="module_name"/>
                    <field name="capability_tag_ids"/>
                    <filter name="filter_core" string="Core" domain="[('category','=','core')]"/>
                    <filter name="filter_compliance" string="Compliance" domain="[('category','=','compliance')]"/>
                    <filter name="filter_ee_gap" string="EE-Gap" domain="[('category','=','ee_gap')]"/>
                    <filter name="filter_operations" string="Operations" domain="[('category','=','operations')]"/>
                    <filter name="filter_vertical" string="Vertical" domain="[('category','=','vertical')]"/>
                    <separator/>
                    <filter name="filter_production" string="Production" domain="[('maturity','=','production')]"/>
                    <filter name="filter_partial" string="Partial" domain="[('maturity','=','partial')]"/>
                    <filter name="filter_scaffold" string="Scaffold" domain="[('maturity','=','scaffold')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_category" string="Category" context="{'group_by':'category'}"/>
                        <filter name="group_maturity" string="Maturity" context="{'group_by':'maturity'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_capability_entry" model="ir.actions.act_window">
            <field name="name">Capability Catalog</field>
            <field name="res_model">custom.module.capability.entry</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_capability_entry_search"/>
        </record>

    </data>
</odoo>
