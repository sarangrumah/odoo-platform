<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_capability_tag_list" model="ir.ui.view">
            <field name="name">custom.module.capability.tag.list</field>
            <field name="model">custom.module.capability.tag</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="technical_code"/>
                    <field name="description"/>
                    <field name="active"/>
                    <field name="color" widget="color_picker"/>
                </list>
            </field>
        </record>

        <record id="view_capability_tag_form" model="ir.ui.view">
            <field name="name">custom.module.capability.tag.form</field>
            <field name="model">custom.module.capability.tag</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="technical_code"/>
                            <field name="active"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_capability_tag" model="ir.actions.act_window">
            <field name="name">Capability Tags</field>
            <field name="res_model">custom.module.capability.tag</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
