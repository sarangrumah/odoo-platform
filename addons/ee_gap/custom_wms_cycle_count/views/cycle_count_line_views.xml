<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cycle_count_line_list" model="ir.ui.view">
        <field name="name">custom.cycle.count.line.list</field>
        <field name="model">custom.cycle.count.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="session_id"/>
                <field name="location_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="expected_qty"/>
                <field name="counted_qty"/>
                <field name="variance_qty"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_cycle_count_line_search" model="ir.ui.view">
        <field name="name">custom.cycle.count.line.search</field>
        <field name="model">custom.cycle.count.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="location_id"/>
                <filter name="has_variance" string="With Variance" domain="[('variance_qty','!=',0)]"/>
                <filter name="pending" string="Pending" domain="[('status','=','pending')]"/>
                <filter name="counted" string="Counted" domain="[('status','=','counted')]"/>
                
                    <filter name="grp_status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="grp_session" string="Session" context="{'group_by':'session_id'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_cycle_count_line" model="ir.actions.act_window">
        <field name="name">Cycle Count Lines</field>
        <field name="res_model">custom.cycle.count.line</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
