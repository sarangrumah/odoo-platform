<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cycle_count_plan_list" model="ir.ui.view">
        <field name="name">custom.cycle.count.plan.list</field>
        <field name="model">custom.cycle.count.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="frequency"/>
                <field name="method"/>
                <field name="next_run_date"/>
                <field name="target_count_per_period"/>
                <field name="coverage_pct" widget="progressbar"/>
                <field name="state"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cycle_count_plan_form" model="ir.ui.view">
        <field name="name">custom.cycle.count.plan.form</field>
        <field name="model">custom.cycle.count.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="warehouse_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="frequency"/>
                        <field name="method"/>
                        <field name="target_count_per_period"/>
                        <field name="next_run_date"/>
                        <field name="state"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="scope_zone_ids" widget="many2many_tags"/>
                        <field name="coverage_pct" widget="progressbar"/>
                    </group>
                    <notebook>
                        <page string="Sessions">
                            <field name="session_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="scheduled_date"/>
                                    <field name="line_count"/>
                                    <field name="variance_count"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_cycle_count_plan" model="ir.actions.act_window">
        <field name="name">Cycle Count Plans</field>
        <field name="res_model">custom.cycle.count.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
