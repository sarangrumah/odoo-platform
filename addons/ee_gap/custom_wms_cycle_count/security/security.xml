<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_cycle_count" model="ir.module.category">
            <field name="name">Cycle Count</field>
            <field name="sequence">26</field>
        </record>

        <record id="group_cycle_count_user" model="res.groups">
            <field name="name">Cycle Count / Counter</field>
            <field name="category_id" ref="module_category_cycle_count"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_cycle_count_supervisor" model="res.groups">
            <field name="name">Cycle Count / Supervisor</field>
            <field name="category_id" ref="module_category_cycle_count"/>
            <field name="implied_ids" eval="[(4, ref('group_cycle_count_user'))]"/>
        </record>

        <record id="group_cycle_count_admin" model="res.groups">
            <field name="name">Cycle Count / Administrator</field>
            <field name="category_id" ref="module_category_cycle_count"/>
            <field name="implied_ids" eval="[(4, ref('group_cycle_count_supervisor')), (4, ref('stock.group_stock_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
