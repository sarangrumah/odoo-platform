<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cycle_count_start_wizard_form" model="ir.ui.view">
        <field name="name">custom.cycle.count.start.wizard.form</field>
        <field name="model">custom.cycle.count.start.wizard</field>
        <field name="arch" type="xml">
            <form string="Start Cycle Count">
                <group>
                    <field name="plan_id"/>
                    <field name="scheduled_date"/>
                    <field name="target_count"/>
                    <field name="user_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_start" type="object" string="Start" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cycle_count_start_wizard" model="ir.actions.act_window">
        <field name="name">Start Cycle Count</field>
        <field name="res_model">custom.cycle.count.start.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
