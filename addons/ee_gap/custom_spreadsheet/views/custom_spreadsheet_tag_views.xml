<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_spreadsheet_tag_list" model="ir.ui.view">
        <field name="name">custom.spreadsheet.tag.list</field>
        <field name="model">custom.spreadsheet.tag</field>
        <field name="arch" type="xml">
            <list string="Spreadsheet Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_custom_spreadsheet_tag_form" model="ir.ui.view">
        <field name="name">custom.spreadsheet.tag.form</field>
        <field name="model">custom.spreadsheet.tag</field>
        <field name="arch" type="xml">
            <form string="Spreadsheet Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_spreadsheet_tag" model="ir.actions.act_window">
        <field name="name">Spreadsheet Tags</field>
        <field name="res_model">custom.spreadsheet.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
