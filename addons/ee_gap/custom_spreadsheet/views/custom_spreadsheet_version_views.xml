<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_spreadsheet_version_list" model="ir.ui.view">
        <field name="name">custom.spreadsheet.version.list</field>
        <field name="model">custom.spreadsheet.version</field>
        <field name="arch" type="xml">
            <list string="Versions">
                <field name="version_no"/>
                <field name="workbook_id"/>
                <field name="saved_by"/>
                <field name="saved_at"/>
                <field name="note"/>
                <button name="action_restore"
                        type="object"
                        string="Restore"
                        icon="fa-undo"/>
            </list>
        </field>
    </record>

    <record id="view_custom_spreadsheet_version_form" model="ir.ui.view">
        <field name="name">custom.spreadsheet.version.form</field>
        <field name="model">custom.spreadsheet.version</field>
        <field name="arch" type="xml">
            <form string="Version">
                <header>
                    <button name="action_restore"
                            type="object"
                            string="Restore this version"
                            class="oe_highlight"
                            icon="fa-undo"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="workbook_id"/>
                            <field name="version_no"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="saved_by"/>
                            <field name="saved_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Snapshot">
                            <field name="data_json_snapshot" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_spreadsheet_version" model="ir.actions.act_window">
        <field name="name">Spreadsheet Versions</field>
        <field name="res_model">custom.spreadsheet.version</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
