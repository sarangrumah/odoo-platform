<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_spreadsheet" model="res.groups.privilege">
            <field name="name">Spreadsheets</field>
            <field name="sequence">115</field>
        </record>

        <record id="group_user" model="res.groups">
            <field name="name">Spreadsheets / User</field>
            <field name="privilege_id" ref="res_groups_privilege_spreadsheet"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Spreadsheets / Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_spreadsheet"/>
            <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
