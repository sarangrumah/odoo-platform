<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_social" model="ir.module.category">
            <field name="name">Social Marketing</field>
            <field name="sequence">104</field>
        </record>
        <record id="group_social_user" model="res.groups">
            <field name="name">Social User</field>
            <field name="category_id" ref="module_category_social"/>
