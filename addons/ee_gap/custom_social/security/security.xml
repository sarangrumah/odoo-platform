        <record id="group_social_admin" model="res.groups">
            <field name="name">Social Admin</field>
            <field name="category_id" ref="module_category_social"/>
            <field name="implied_ids" eval="[Command.link(ref('group_social_user'))]"/>
        </record>
    </data>
</odoo>
