<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_maintenance_team_sla_list" model="ir.ui.view">
        <field name="name">custom.maintenance.team.sla.list</field>
        <field name="model">custom.maintenance.team.sla</field>
        <field name="arch" type="xml">
            <list string="Maintenance SLAs">
                <field name="name"/>
                <field name="team_id"/>
                <field name="priority"/>
                <field name="response_hours"/>
                <field name="resolve_hours"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_custom_maintenance_team_sla_form" model="ir.ui.view">
        <field name="name">custom.maintenance.team.sla.form</field>
        <field name="model">custom.maintenance.team.sla</field>
        <field name="arch" type="xml">
            <form string="Maintenance SLA">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_id"/>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="response_hours"/>
                            <field name="resolve_hours"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_custom_maintenance_team_sla_search" model="ir.ui.view">
        <field name="name">custom.maintenance.team.sla.search</field>
        <field name="model">custom.maintenance.team.sla</field>
        <field name="arch" type="xml">
            <search string="SLAs">
                <field name="name"/>
                <field name="team_id"/>
                <field name="priority"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <separator/>
                <filter name="group_team" string="Team" context="{'group_by':'team_id'}"/>
                <filter name="group_priority" string="Priority" context="{'group_by':'priority'}"/>
            </search>
        </field>
    </record>

    <record id="action_custom_maintenance_team_sla" model="ir.actions.act_window">
        <field name="name">Maintenance SLAs</field>
        <field name="res_model">custom.maintenance.team.sla</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_custom_maintenance_team_sla_search"/>
    </record>
</odoo>
