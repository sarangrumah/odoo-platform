<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_doc_workspace_list" model="ir.ui.view">
        <field name="name">document.workspace.list</field>
        <field name="model">document.workspace</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="default_classification_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_doc_workspace_form" model="ir.ui.view">
        <field name="name">document.workspace.form</field>
        <field name="model">document.workspace</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="default_classification_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Members"/>
                    <field name="member_ids" widget="many2many_tags"/>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_doc_workspace" model="ir.actions.act_window">
        <field name="name">Workspaces</field>
        <field name="res_model">document.workspace</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
