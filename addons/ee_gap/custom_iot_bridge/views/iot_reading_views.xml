<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_reading_list" model="ir.ui.view">
        <field name="name">iot.reading.list</field>
        <field name="model">iot.reading</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0">
                <field name="recorded_at"/>
                <field name="device_id"/>
                <field name="metric"/>
                <field name="value"/>
                <field name="unit"/>
            </list>
        </field>
    </record>
    <record id="view_iot_reading_search" model="ir.ui.view">
        <field name="name">iot.reading.search</field>
        <field name="model">iot.reading</field>
        <field name="arch" type="xml">
            <search>
                <field name="device_id"/>
                <field name="metric"/>
                <filter name="last_hour" string="Last hour"
                        domain="[('recorded_at','&gt;=', (datetime.datetime.utcnow() - datetime.timedelta(hours=1)).isoformat())]"/>
                <group>
                    <filter name="by_device" string="Device" context="{'group_by': 'device_id'}"/>
                    <filter name="by_metric" string="Metric" context="{'group_by': 'metric'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_iot_reading" model="ir.actions.act_window">
        <field name="name">Readings</field>
        <field name="res_model">iot.reading</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_iot_reading_search"/>
    </record>
</odoo>
