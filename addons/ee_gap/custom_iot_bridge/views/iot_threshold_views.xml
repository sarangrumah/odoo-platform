<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_threshold_list" model="ir.ui.view">
        <field name="name">iot.threshold.list</field>
        <field name="model">iot.threshold</field>
        <field name="arch" type="xml">
            <list decoration-danger="alert_active">
                <field name="device_id"/>
                <field name="metric"/>
                <field name="condition"/>
                <field name="threshold_value"/>
                <field name="severity" widget="badge"/>
                <field name="alert_active" widget="boolean_toggle"/>
                <field name="last_evaluated_at"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_iot_threshold" model="ir.actions.act_window">
        <field name="name">Thresholds</field>
        <field name="res_model">iot.threshold</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
