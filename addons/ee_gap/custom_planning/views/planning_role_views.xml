<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_planning_role_list" model="ir.ui.view">
        <field name="name">planning.role.list</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_planning_role" model="ir.actions.act_window">
        <field name="name">Planning Roles</field>
        <field name="res_model">planning.role</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
