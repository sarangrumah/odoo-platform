<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fixed_asset_group_list" model="ir.ui.view">
        <field name="name">custom.fixed.asset.group.list</field>
        <field name="model">custom.fixed.asset.group</field>
        <field name="arch" type="xml">
            <list string="Asset Groups">
                <field name="code"/>
                <field name="name"/>
                <field name="default_useful_life_months"/>
                <field name="default_asset_account_id"/>
                <field name="default_depreciation_account_id"/>
                <field name="default_expense_account_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_fixed_asset_group_form" model="ir.ui.view">
        <field name="name">custom.fixed.asset.group.form</field>
        <field name="model">custom.fixed.asset.group</field>
        <field name="arch" type="xml">
            <form string="Asset Group">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="default_useful_life_months"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="default_asset_account_id"/>
                            <field name="default_depreciation_account_id"/>
                            <field name="default_expense_account_id"/>
                            <field name="default_journal_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fixed_asset_group" model="ir.actions.act_window">
        <field name="name">Asset Groups</field>
        <field name="res_model">custom.fixed.asset.group</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
