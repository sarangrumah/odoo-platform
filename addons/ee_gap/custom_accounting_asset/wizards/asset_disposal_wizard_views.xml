<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_disposal_wizard_form" model="ir.ui.view">
        <field name="name">custom.fixed.asset.disposal.wizard.form</field>
        <field name="model">custom.fixed.asset.disposal.wizard</field>
        <field name="arch" type="xml">
            <form string="Dispose Asset">
                <group>
                    <field name="asset_id" readonly="1"/>
                    <field name="net_book_value"/>
                    <field name="disposal_date"/>
                    <field name="disposal_value"/>
                    <field name="gain_loss"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <group string="Posting">
                    <field name="create_journal_entry"/>
                    <field name="receivable_account_id"
                           invisible="not create_journal_entry"/>
                    <field name="gain_account_id"
                           invisible="not create_journal_entry"/>
                    <field name="loss_account_id"
                           invisible="not create_journal_entry"/>
                </group>
                <group>
                    <field name="note" nolabel="1" placeholder="Disposal notes..."/>
                </group>
                <footer>
                    <button name="action_dispose" type="object" string="Dispose"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
