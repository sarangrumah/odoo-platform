<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_post_depreciation" model="ir.cron">
        <field name="name">Custom Asset: Post Monthly Depreciation</field>
        <field name="model_id" ref="model_custom_fixed_asset"/>
        <field name="state">code</field>
        <field name="code">model._cron_post_depreciation() if hasattr(model, '_cron_post_depreciation') else None</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
