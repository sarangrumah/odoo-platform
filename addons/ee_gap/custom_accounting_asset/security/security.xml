<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_accounting_assets" model="ir.module.category">
            <field name="name">Accounting / Fixed Assets</field>
            <field name="description">Fixed asset register and depreciation</field>
            <field name="sequence">82</field>
        </record>

        <record id="group_asset_user" model="res.groups">
            <field name="name">Asset User</field>
            <field name="category_id" ref="module_category_accounting_assets"/>
        </record>

        <record id="group_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_accounting_assets"/>
            <field name="implied_ids" eval="[Command.link(ref('group_asset_user'))]"/>
        </record>

    </data>
</odoo>
