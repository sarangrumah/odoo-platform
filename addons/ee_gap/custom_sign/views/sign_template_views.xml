<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sign_template_list" model="ir.ui.view">
        <field name="name">sign.template.list</field>
        <field name="model">sign.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="attachment_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_sign_template_form" model="ir.ui.view">
        <field name="name">sign.template.form</field>
        <field name="model">sign.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <field name="attachment_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="active"/>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_sign_template" model="ir.actions.act_window">
        <field name="name">Sign Templates</field>
        <field name="res_model">sign.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
