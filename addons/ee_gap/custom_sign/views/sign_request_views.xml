<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sign_request_list" model="ir.ui.view">
        <field name="name">sign.request.list</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'signed'"
                  decoration-info="state in ('sent', 'partially_signed')"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="template_id"/>
                <field name="signed_count"/>
                <field name="total_signers"/>
                <field name="requested_by_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_sign_request_form" model="ir.ui.view">
        <field name="name">sign.request.form</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send" string="Send" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('signed','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="requested_by_id"/>
                        </group>
                        <group>
                            <field name="sent_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                            <field name="signed_count" readonly="1"/>
                            <field name="total_signers" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Signers"/>
                    <field name="signer_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="role"/>
                            <field name="partner_id"/>
                            <field name="state" widget="badge"/>
                            <field name="opened_at" readonly="1"/>
                            <field name="signed_at" readonly="1"/>
                        </list>
                    </field>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_sign_request" model="ir.actions.act_window">
        <field name="name">Sign Requests</field>
        <field name="res_model">sign.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
