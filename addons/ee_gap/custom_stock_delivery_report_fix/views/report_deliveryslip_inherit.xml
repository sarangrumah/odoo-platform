<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Upstream Odoo 19's stock.stock_report_delivery_has_serial_move_line
        references move_line.packaging_uom_id, but packaging_uom_id is
        defined on stock.move (see stock/models/stock_move.py), not on
        stock.move.line. Rendering the delivery slip raises:
            AttributeError: 'stock.move.line' object has no attribute 'packaging_uom_id'
        We replace the broken block to read the field from move_id, and
        guard against an unset packaging.
    -->
    <template id="stock_report_delivery_has_serial_move_line_fix"
              inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//t[@t-if='move_line.packaging_uom_id != move_line.product_uom_id']"
               position="replace">
            <t t-if="move_line.move_id.packaging_uom_id and move_line.move_id.packaging_uom_id != move_line.product_uom_id"
               groups="uom.group_uom">
                <br/>
                <span class="text-muted"
                      t-esc="move_line.product_uom_id._compute_quantity(move_line.quantity, move_line.move_id.packaging_uom_id)">1.00</span>
                <span class="text-muted"
                      t-field="move_line.move_id.packaging_uom_id">Pack of 6</span>
            </t>
        </xpath>
    </template>
</odoo>
