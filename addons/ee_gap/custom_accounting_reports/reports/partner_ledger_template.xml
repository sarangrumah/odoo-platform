<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_partner_ledger">
            <t t-call="custom_accounting_reports.report_header"/>
            <t t-foreach="lines" t-as="line">
                <div t-if="line.get('type') == 'partner'" class="mb-4">
                    <h5 class="mb-1" t-esc="line['partner_name']"/>
                    <table class="table table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Move</th>
                                <th>Account</th>
                                <th>Label</th>
                                <th class="text-end">Debit</th>
                                <th class="text-end">Credit</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="fw-bold">
                                <td colspan="6">Opening Balance</td>
                                <td class="text-end">
                                    <span t-esc="line['opening']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                            </tr>
                            <tr t-foreach="line['lines']" t-as="ml">
                                <td t-esc="ml['date']"/>
                                <td t-esc="ml['move_name']"/>
                                <td t-esc="ml['account_code']"/>
                                <td t-esc="ml['label']"/>
                                <td class="text-end">
                                    <span t-esc="ml['debit']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="ml['credit']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="ml['running_balance']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                            </tr>
                            <tr class="fw-bold table-secondary">
                                <td colspan="4">Closing Balance</td>
                                <td class="text-end">
                                    <span t-esc="line['total_debit']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="line['total_credit']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="line['closing']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div t-if="line.get('type') == 'grand_total'"
                     class="alert alert-secondary fw-bold">
                    <span t-esc="line['label']"/>:
                    <span t-esc="line['closing']"
                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                </div>
            </t>
            <t t-call="custom_accounting_reports.report_footer_signature"/>
        </template>
    </data>
</odoo>
