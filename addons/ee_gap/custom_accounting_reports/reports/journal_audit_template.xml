<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_journal_audit">
            <t t-call="custom_accounting_reports.report_header"/>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Journal</th>
                        <th>Move</th>
                        <th>Reference</th>
                        <th>State</th>
                        <th>Posted By</th>
                        <th>Posted On</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="lines" t-as="line"
                        t-if="line.get('type') == 'move'">
                        <td t-esc="line['date']"/>
                        <td t-esc="line['journal_code']"/>
                        <td t-esc="line['move_name']"/>
                        <td t-esc="line['reference']"/>
                        <td t-esc="line['state']"/>
                        <td t-esc="line['posted_by']"/>
                        <td t-esc="line['posted_on']"/>
                        <td class="text-end">
                            <span t-esc="line['amount_total']"
                                  t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                        </td>
                    </tr>
                </tbody>
            </table>
            <t t-call="custom_accounting_reports.report_footer_signature"/>
        </template>
    </data>
</odoo>
