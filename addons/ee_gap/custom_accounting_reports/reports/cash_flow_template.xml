<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_cash_flow">
            <t t-call="custom_accounting_reports.report_header"/>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Section / Account</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="lines" t-as="line">
                        <tr t-if="line.get('type') == 'section'"
                            class="table-light">
                            <td>
                                <strong t-esc="line['label']"/>
                            </td>
                            <td class="text-end fw-bold">
                                <span t-esc="line['subtotal']"
                                      t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </td>
                        </tr>
                        <t t-if="line.get('type') == 'section'">
                            <tr t-foreach="line['accounts']" t-as="acc">
                                <td class="ps-4">
                                    <span t-esc="acc['account_code']"/>
                                    <span t-esc="acc['account_name']"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="acc['signed_balance']"
                                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                            </tr>
                        </t>
                        <tr t-if="line.get('type') == 'subtotal'"
                            class="fw-bold">
                            <td t-esc="line['label']"/>
                            <td class="text-end">
                                <span t-esc="line['signed_balance']"
                                      t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </td>
                        </tr>
                        <tr t-if="line.get('type') == 'grand_total'"
                            class="table-secondary fw-bold">
                            <td t-esc="line['label']"/>
                            <td class="text-end">
                                <span t-esc="line['signed_balance']"
                                      t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </td>
                        </tr>
                        <tr t-if="line.get('type') == 'check'"
                            class="table-warning fst-italic">
                            <td t-esc="line['label']"/>
                            <td class="text-end">
                                <span t-esc="line['signed_balance']"
                                      t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
            <t t-call="custom_accounting_reports.report_footer_signature"/>
        </template>
    </data>
</odoo>
