<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_technician_list" model="ir.ui.view">
        <field name="name">fsm.technician.list</field>
        <field name="model">fsm.technician</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="user_id"/>
                <field name="phone"/>
                <field name="open_wo_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_fsm_technician_form" model="ir.ui.view">
        <field name="name">fsm.technician.form</field>
        <field name="model">fsm.technician</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="employee_id"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Skills"/>
                    <field name="skill_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fsm_technician" model="ir.actions.act_window">
        <field name="name">Technicians</field>
        <field name="res_model">fsm.technician</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
