<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_intercompany_rule_form_inherit_procurement" model="ir.ui.view">
        <field name="name">account.intercompany.rule.form.procurement</field>
        <field name="model">account.intercompany.rule</field>
        <field name="inherit_id" ref="custom_accounting_full.view_ic_rule_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='auto_validate']" position="after">
                <field name="mirror_purchase_order"/>
                <field name="mirror_picking"/>
                <field name="target_warehouse_id"/>
                <field name="target_sale_journal_id"/>
            </xpath>
        </field>
    </record>
</odoo>
