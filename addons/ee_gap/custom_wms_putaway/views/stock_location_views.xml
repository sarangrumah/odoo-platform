<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_location_form_inherit_putaway" model="ir.ui.view">
        <field name="name">stock.location.form.inherit.putaway</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Putaway Volumetrics">
                    <field name="volume_capacity_m3"/>
                    <field name="volume_used_m3"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
