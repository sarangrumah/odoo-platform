<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_putaway_rule_list" model="ir.ui.view">
        <field name="name">custom.wms.putaway.rule.list</field>
        <field name="model">custom.wms.putaway.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="strategy_id"/>
                <field name="tier"/>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="kind"/>
                <field name="target_location_id"/>
                <field name="abc_class"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_putaway_rule_form" model="ir.ui.view">
        <field name="name">custom.wms.putaway.rule.form</field>
        <field name="model">custom.wms.putaway.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="strategy_id"/>
                        <field name="name"/>
                        <field name="tier"/>
                        <field name="sequence"/>
                        <field name="kind"/>
                        <field name="active"/>
                    </group>
                    <group string="Targeting">
                        <field name="target_location_id"/>
                        <field name="target_location_domain"/>
                        <field name="product_domain"/>
                        <field name="abc_class"/>
                        <field name="temperature_zone"/>
                    </group>
                    <group string="Custom Python" invisible="kind != 'custom_python'">
                        <field name="custom_python" nolabel="1"/>
                    </group>
                    <group string="Weights">
                        <field name="weight_volume"/>
                        <field name="weight_distance"/>
                        <field name="weight_age"/>
                        <field name="weight_abc"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_putaway_rule_search" model="ir.ui.view">
        <field name="name">custom.wms.putaway.rule.search</field>
        <field name="model">custom.wms.putaway.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="strategy_id"/>
                <field name="kind"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>

                    <filter name="grp_strategy" string="Strategy" context="{'group_by':'strategy_id'}"/>
                    <filter name="grp_tier" string="Tier" context="{'group_by':'tier'}"/>

            </search>
        </field>
    </record>

    <record id="action_putaway_rule" model="ir.actions.act_window">
        <field name="name">Putaway Rules</field>
        <field name="res_model">custom.wms.putaway.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
