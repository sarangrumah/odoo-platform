<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_putaway_user" model="res.groups">
            <field name="name">Putaway / User</field>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_putaway_admin" model="res.groups">
            <field name="name">Putaway / Administrator</field>
            <field name="implied_ids" eval="[(4, ref('group_putaway_user')), (4, ref('stock.group_stock_manager'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
