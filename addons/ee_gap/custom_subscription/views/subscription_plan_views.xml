<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_plan_list" model="ir.ui.view">
        <field name="name">subscription.plan.list</field>
        <field name="model">subscription.plan</field>
        <field name="arch" type="xml">
            <list string="Plans">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="recurring_interval"/>
                <field name="recurring_count"/>
                <field name="price"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="trial_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_subscription_plan_form" model="ir.ui.view">
        <field name="name">subscription.plan.form</field>
        <field name="model">subscription.plan</field>
        <field name="arch" type="xml">
            <form string="Plan">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="product_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="recurring_interval"/>
                            <field name="recurring_count"/>
                            <field name="price"/>
                            <field name="currency_id"/>
                            <field name="trial_days"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_subscription_plan" model="ir.actions.act_window">
        <field name="name">Plans</field>
        <field name="res_model">subscription.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
