<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_subscription" model="res.groups.privilege">
            <field name="name">Subscriptions</field>
            <field name="sequence">130</field>
            <field name="category_id" ref="custom_core.module_category_custom_platform"/>
        </record>

        <record id="group_user" model="res.groups">
            <field name="name">Subscriptions / User</field>
            <field name="privilege_id" ref="res_groups_privilege_subscription"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Subscriptions / Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_subscription"/>
            <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="seq_subscription_contract" model="ir.sequence">
            <field name="name">Subscription Contract</field>
            <field name="code">subscription.contract</field>
            <field name="prefix">SUB/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
