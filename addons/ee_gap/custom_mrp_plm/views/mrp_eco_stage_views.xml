<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_eco_stage_list" model="ir.ui.view">
        <field name="name">mrp.eco.stage.list</field>
        <field name="model">mrp.eco.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_approval"/>
                <field name="is_final"/>
                <field name="folded"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_eco_stage" model="ir.actions.act_window">
        <field name="name">ECO Stages</field>
        <field name="res_model">mrp.eco.stage</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
