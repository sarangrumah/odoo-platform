<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_timesheet_wizard_form" model="ir.ui.view">
        <field name="name">custom.timesheet.invoice.wizard.form</field>
        <field name="model">custom.timesheet.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Timesheets">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="sale_order_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="selected"/>
                        <field name="date"/>
                        <field name="employee_id"/>
                        <field name="project_id"/>
                        <field name="unit_amount"/>
                        <field name="billing_rate"/>
                        <field name="analytic_line_id" invisible="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_preview" type="object"
                            string="Preview" class="btn-secondary"/>
                    <button name="action_create_invoice" type="object"
                            string="Create Draft Invoice" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_timesheet_wizard" model="ir.actions.act_window">
        <field name="name">Invoice Timesheets</field>
        <field name="res_model">custom.timesheet.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
