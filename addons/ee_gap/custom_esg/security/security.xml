<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="res_groups_privilege_esg" model="res.groups.privilege">
            <field name="name">ESG Reporting</field>
            <field name="sequence">85</field>
        </record>

        <record id="group_esg_user" model="res.groups">
            <field name="name">ESG / User</field>
            <field name="privilege_id" ref="res_groups_privilege_esg"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_esg_manager" model="res.groups">
            <field name="name">ESG / Manager (Auditor)</field>
            <field name="privilege_id" ref="res_groups_privilege_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
