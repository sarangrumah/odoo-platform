<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_custom_esg_measurement_list" model="ir.ui.view">
        <field name="name">custom.esg.measurement.list</field>
        <field name="model">custom.esg.measurement</field>
        <field name="arch" type="xml">
            <list string="ESG Measurements">
                <field name="metric_id"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="value"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_custom_esg_measurement_form" model="ir.ui.view">
        <field name="name">custom.esg.measurement.form</field>
        <field name="model">custom.esg.measurement</field>
        <field name="arch" type="xml">
            <form string="ESG Measurement">
                <header>
                    <button name="action_validate" type="object" string="Validate"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_audit" type="object" string="Mark Audited"
                            class="oe_highlight" invisible="state != 'validated'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,validated,audited"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="metric_id"/>
                            <field name="value"/>
                            <field name="source_document"/>
                        </group>
                        <group>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="validated_by_user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_custom_esg_measurement_search" model="ir.ui.view">
        <field name="name">custom.esg.measurement.search</field>
        <field name="model">custom.esg.measurement</field>
        <field name="arch" type="xml">
            <search string="ESG Measurements">
                <field name="metric_id"/>
                <field name="source_document"/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Validated" name="filter_validated" domain="[('state','=','validated')]"/>
                <filter string="Audited" name="filter_audited" domain="[('state','=','audited')]"/>
                <separator/>
                <filter string="By Metric" name="group_metric" context="{'group_by': 'metric_id'}"/>
                <filter string="By Status" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="By Period End" name="group_period" context="{'group_by': 'period_end'}"/>
            </search>
        </field>
    </record>

    <record id="action_custom_esg_measurement" model="ir.actions.act_window">
        <field name="name">ESG Measurements</field>
        <field name="res_model">custom.esg.measurement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_custom_esg_measurement_search"/>
    </record>

</odoo>
