<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dedup_candidate_list" model="ir.ui.view">
        <field name="name">custom.dedup.candidate.list</field>
        <field name="model">custom.dedup.candidate</field>
        <field name="arch" type="xml">
            <list string="Dedup Candidates"
                  decoration-success="state == 'merged'"
                  decoration-muted="state == 'dismissed'">
                <field name="rule_id"/>
                <field name="preview"/>
                <field name="match_key"/>
                <field name="state" widget="badge"/>
                <field name="created_at"/>
                <button name="action_open_merge_wizard"
                        type="object"
                        string="Merge"
                        icon="fa-compress"
                        invisible="state != 'pending'"/>
                <button name="action_dismiss"
                        type="object"
                        string="Dismiss"
                        icon="fa-times"
                        invisible="state != 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_dedup_candidate_form" model="ir.ui.view">
        <field name="name">custom.dedup.candidate.form</field>
        <field name="model">custom.dedup.candidate</field>
        <field name="arch" type="xml">
            <form string="Dedup Candidate">
                <header>
                    <button name="action_open_merge_wizard"
                            type="object"
                            string="Merge"
                            class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_dismiss"
                            type="object"
                            string="Dismiss"
                            invisible="state != 'pending'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="rule_id"/>
                            <field name="state" widget="badge"/>
                            <field name="created_at"/>
                        </group>
                        <group>
                            <field name="preview"/>
                            <field name="match_key"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Record IDs (JSON)">
                            <field name="res_ids_json" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dedup_candidate" model="ir.actions.act_window">
        <field name="name">Dedup Candidates</field>
        <field name="res_model">custom.dedup.candidate</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
