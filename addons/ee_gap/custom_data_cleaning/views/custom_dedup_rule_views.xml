<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dedup_rule_list" model="ir.ui.view">
        <field name="name">custom.dedup.rule.list</field>
        <field name="model">custom.dedup.rule</field>
        <field name="arch" type="xml">
            <list string="Dedup Rules" decoration-muted="not is_active">
                <field name="name"/>
                <field name="model_name"/>
                <field name="match_fields"/>
                <field name="normalize_phone_id"/>
                <field name="normalize_email_case"/>
                <field name="cron_active" widget="boolean_toggle"/>
                <field name="last_run_at"/>
                <field name="last_match_count"/>
                <field name="candidate_count"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_dedup_rule_form" model="ir.ui.view">
        <field name="name">custom.dedup.rule.form</field>
        <field name="model">custom.dedup.rule</field>
        <field name="arch" type="xml">
            <form string="Dedup Rule">
                <header>
                    <button name="action_run_scan"
                            type="object"
                            string="Run Scan"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Partner phone duplicates"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_name" placeholder="res.partner"/>
                            <field name="match_fields" placeholder="phone, mobile"/>
                            <field name="is_active"/>
                            <field name="cron_active"/>
                            <field name="cron_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="normalize_phone_id"/>
                            <field name="normalize_email_case"/>
                            <field name="last_run_at"/>
                            <field name="last_match_count"/>
                            <field name="candidate_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Candidates">
                            <field name="candidate_ids">
                                <list>
                                    <field name="preview"/>
                                    <field name="match_key"/>
                                    <field name="state" widget="badge"/>
                                    <field name="created_at"/>
                                    <button name="action_open_merge_wizard"
                                            type="object"
                                            string="Merge"
                                            icon="fa-compress"
                                            invisible="state != 'pending'"/>
                                    <button name="action_dismiss"
                                            type="object"
                                            string="Dismiss"
                                            icon="fa-times"
                                            invisible="state != 'pending'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_dedup_rule_search" model="ir.ui.view">
        <field name="name">custom.dedup.rule.search</field>
        <field name="model">custom.dedup.rule</field>
        <field name="arch" type="xml">
            <search string="Dedup Rules">
                <field name="name"/>
                <field name="model_name"/>
                <field name="match_fields"/>
                <filter name="active" string="Active"
                        domain="[('is_active','=',True)]"/>
                <filter name="inactive" string="Inactive"
                        domain="[('is_active','=',False)]"/>
                <filter name="scheduled" string="Scheduled"
                        domain="[('cron_active','=',True)]"/>
                <separator/>
                <filter name="group_model" string="Model" context="{'group_by':'model_name'}"/>
                <filter name="group_active" string="Active" context="{'group_by':'is_active'}"/>
            </search>
        </field>
    </record>

    <record id="action_dedup_rule" model="ir.actions.act_window">
        <field name="name">Dedup Rules</field>
        <field name="res_model">custom.dedup.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dedup_rule_search"/>
    </record>

</odoo>
