<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dedup_merge_wizard_form" model="ir.ui.view">
        <field name="name">custom.dedup.merge.wizard.form</field>
        <field name="model">custom.dedup.merge.wizard</field>
        <field name="arch" type="xml">
            <form string="Merge Duplicates">
                <sheet>
                    <group>
                        <field name="candidate_id" readonly="1"/>
                        <field name="model_name" readonly="1"/>
                        <field name="preview" readonly="1"/>
                        <field name="record_ids_json" readonly="1"/>
                        <field name="master_id_int"/>
                    </group>
                    <p class="text-muted">
                        The record with ID = Master will be kept. All other
                        duplicates will be merged into it. Foreign keys
                        pointing at the duplicates are rewritten to the master.
                        Conflicting field values are preserved on the master
                        and logged to its audit trail.
                    </p>
                </sheet>
                <footer>
                    <button name="action_merge"
                            type="object"
                            string="Merge"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dedup_merge_wizard" model="ir.actions.act_window">
        <field name="name">Merge Duplicates</field>
        <field name="res_model">custom.dedup.merge.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
