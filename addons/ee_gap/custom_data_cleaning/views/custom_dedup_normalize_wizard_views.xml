<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dedup_normalize_wizard_form" model="ir.ui.view">
        <field name="name">custom.dedup.normalize.wizard.form</field>
        <field name="model">custom.dedup.normalize.wizard</field>
        <field name="arch" type="xml">
            <form string="Normalize Data">
                <sheet>
                    <group>
                        <group>
                            <field name="target_model"/>
                            <field name="target_field"/>
                            <field name="action"/>
                        </group>
                        <group>
                            <field name="result_summary" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run"
                            type="object"
                            string="Run"
                            class="btn-primary"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dedup_normalize_wizard" model="ir.actions.act_window">
        <field name="name">Normalize Tools</field>
        <field name="res_model">custom.dedup.normalize.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
