<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_custom_expense_corporate_card_list" model="ir.ui.view">
        <field name="name">custom.expense.corporate.card.list</field>
        <field name="model">custom.expense.corporate.card</field>
        <field name="arch" type="xml">
            <list string="Corporate Cards">
                <field name="name"/>
                <field name="masked_number"/>
                <field name="employee_id"/>
                <field name="bank_journal_id"/>
                <field name="expense_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_custom_expense_corporate_card_form" model="ir.ui.view">
        <field name="name">custom.expense.corporate.card.form</field>
        <field name="model">custom.expense.corporate.card</field>
        <field name="arch" type="xml">
            <form string="Corporate Card">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_expenses"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money">
                            <field name="expense_count" widget="statinfo" string="Expenses"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Card label"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="masked_number" placeholder="**** **** **** 1234"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="bank_journal_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_custom_expense_corporate_card_search" model="ir.ui.view">
        <field name="name">custom.expense.corporate.card.search</field>
        <field name="model">custom.expense.corporate.card</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="masked_number"/>
                <field name="employee_id"/>
                <field name="bank_journal_id"/>
                <separator/>
                <filter name="filter_active" string="Active" domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_custom_expense_corporate_card" model="ir.actions.act_window">
        <field name="name">Corporate Cards</field>
        <field name="res_model">custom.expense.corporate.card</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
