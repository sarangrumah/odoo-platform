<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_expense_form_custom_inherit" model="ir.ui.view">
        <field name="name">hr.expense.form.custom.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_ai_extract_receipt"
                        type="object"
                        string="AI Extract Receipt"
                        icon="fa-magic"
                        groups="custom_expenses.group_user"/>
                <button name="action_request_approval_expense"
                        type="object"
                        string="Request Approval"
                        class="oe_highlight"
                        groups="custom_expenses.group_user"
                        invisible="x_custom_approval_state in ('pending','approved')"/>
                <button name="action_open_approval_request"
                        type="object"
                        string="View Approval"
                        groups="custom_expenses.group_user"
                        invisible="not x_custom_approval_request_id"/>
                <button name="action_register_reimbursement_payment"
                        type="object"
                        string="Register Reimbursement"
                        groups="custom_expenses.group_manager"
                        invisible="x_custom_approval_state != 'approved' or x_corporate_card_id"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="Corporate Card / Mileage" name="card_mileage">
                        <group>
                            <group string="Corporate Card">
                                <field name="x_corporate_card_id"/>
                            </group>
                            <group string="Mileage">
                                <field name="x_is_mileage" readonly="1"/>
                                <field name="x_mileage_km"
                                       invisible="not x_is_mileage"/>
                                <field name="x_mileage_rate"
                                       invisible="not x_is_mileage"/>
                            </group>
                        </group>
                    </page>
                    <page string="AI Receipt OCR" name="ai_receipt_ocr">
                        <group>
                            <group string="Extracted">
                                <field name="x_ai_extracted_vendor"/>
                                <field name="x_ai_extracted_amount"/>
                                <field name="x_ai_extracted_tax_amount"/>
                                <field name="x_ai_extracted_currency_code"/>
                                <field name="x_ai_extracted_date"/>
                                <field name="x_ai_confidence"/>
                            </group>
                            <group string="Approval">
                                <field name="x_custom_approval_request_id" readonly="1"/>
                                <field name="x_custom_approval_state" widget="badge" readonly="1"/>
                            </group>
                        </group>
                        <separator string="Raw OCR Text"/>
                        <field name="x_receipt_ocr_text" widget="text" nolabel="1"/>
                    </page>
                </notebook>
            </xpath>

        </field>
    </record>

    <record id="view_hr_expense_tree_custom_inherit" model="ir.ui.view">
        <field name="name">hr.expense.list.custom.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.view_expenses_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="x_ai_extracted_vendor" optional="hide"/>
                <field name="x_ai_extracted_amount" optional="hide"/>
                <field name="x_ai_confidence" optional="hide"/>
                <field name="x_corporate_card_id" optional="hide"/>
                <field name="x_is_mileage" optional="hide"/>
                <field name="x_custom_approval_state" widget="badge" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="action_hr_expense_custom" model="ir.actions.act_window">
        <field name="name">Expenses (AI / Approval)</field>
        <field name="res_model">hr.expense</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
