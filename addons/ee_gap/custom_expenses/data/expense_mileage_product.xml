<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="product_expense_mileage_template" model="product.template">
            <field name="name">Mileage</field>
            <field name="default_code">MILEAGE</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="False"/>
            <field name="purchase_ok" eval="False"/>
            <field name="can_be_expensed" eval="True"/>
            <field name="list_price">5000.0</field>
            <field name="standard_price">5000.0</field>
            <field name="publish_date" eval="time.strftime('%Y-%m-%d')"/>
        </record>
    </data>
</odoo>
