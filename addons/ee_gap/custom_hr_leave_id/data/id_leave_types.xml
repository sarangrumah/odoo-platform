<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Indonesian leave types per UU Ketenagakerjaan / UU Cipta Kerja.
        Each maps to an hr.leave.type with sensible defaults; HR may adjust
        per-tenant.
    -->
    <record id="leave_type_cuti_tahunan" model="hr.leave.type">
        <field name="name">Cuti Tahunan</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">yes</field>
        <field name="employee_requests">yes</field>
        <field name="allocation_validation_type">hr</field>
        <field name="leave_validation_type">manager</field>
        <field name="request_unit">day</field>
        <field name="color">2</field>
    </record>

    <record id="leave_type_cuti_haid" model="hr.leave.type">
        <field name="name">Cuti Haid</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">manager</field>
        <field name="request_unit">day</field>
        <field name="color">9</field>
    </record>

    <record id="leave_type_cuti_melahirkan" model="hr.leave.type">
        <field name="name">Cuti Melahirkan (Maternity)</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">hr</field>
        <field name="request_unit">day</field>
        <field name="color">8</field>
    </record>

    <record id="leave_type_cuti_ayah" model="hr.leave.type">
        <field name="name">Cuti Ayah (Paternity)</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">manager</field>
        <field name="request_unit">day</field>
        <field name="color">4</field>
    </record>

    <record id="leave_type_cuti_besar" model="hr.leave.type">
        <field name="name">Cuti Besar (Long Service)</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">yes</field>
        <field name="employee_requests">yes</field>
        <field name="allocation_validation_type">hr</field>
        <field name="leave_validation_type">hr</field>
        <field name="request_unit">day</field>
        <field name="color">5</field>
    </record>

    <record id="leave_type_cuti_alasan_penting" model="hr.leave.type">
        <field name="name">Cuti Alasan Penting</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">manager</field>
        <field name="request_unit">day</field>
        <field name="color">6</field>
    </record>

    <record id="leave_type_cltl" model="hr.leave.type">
        <field name="name">Cuti di Luar Tanggungan</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">hr</field>
        <field name="request_unit">day</field>
        <field name="color">1</field>
    </record>

    <record id="leave_type_sakit" model="hr.leave.type">
        <field name="name">Cuti Sakit</field>
        <field name="time_type">leave</field>
        <field name="requires_allocation">no</field>
        <field name="employee_requests">yes</field>
        <field name="leave_validation_type">manager</field>
        <field name="request_unit">day</field>
        <field name="color">3</field>
    </record>
</odoo>
