<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_pos_form_inherit_pos_id" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.pos.id</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="E-Receipt (Indonesia)">
                    <group>
                        <field name="x_eperformance_receipt_channel"/>
                        <field name="x_eperformance_receipt_sent" readonly="1"/>
                    </group>
                    <group>
                        <button name="action_send_ereceipt"
                                type="object"
                                string="Send E-Receipt"
                                class="btn-primary"
                                groups="custom_pos_id.group_user"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
