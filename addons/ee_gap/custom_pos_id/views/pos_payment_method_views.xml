<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_id" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.pos.id</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="QRIS (Indonesia)">
                    <group>
                        <field name="x_qris_provider"/>
                        <field name="x_qris_merchant_id"/>
                        <field name="x_qris_mid"/>
                    </group>
                    <group>
                        <field name="x_qris_dynamic_supported"/>
                        <field name="x_qris_static_qr" widget="image"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
