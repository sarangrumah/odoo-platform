<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nlq_session_list" model="ir.ui.view">
        <field name="name">ai.nlq.session.list</field>
        <field name="model">ai.nlq.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="name"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>
    <record id="view_nlq_session_form" model="ir.ui.view">
        <field name="name">ai.nlq.session.form</field>
        <field name="model">ai.nlq.session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <field name="user_id" readonly="1"/>
                    </group>
                    <separator string="Messages"/>
                    <field name="message_ids" readonly="1">
                        <list>
                            <field name="create_date"/>
                            <field name="role"/>
                            <field name="content"/>
                            <field name="is_error" widget="boolean_toggle"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nlq_session" model="ir.actions.act_window">
        <field name="name">NLQ Sessions</field>
        <field name="res_model">ai.nlq.session</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
