<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_ai_features" model="ir.module.category">
            <field name="name">AI Features</field>
            <field name="sequence">82</field>
        </record>

        <record id="group_ai_user" model="res.groups">
            <field name="name">AI Features User</field>
            <field name="category_id" ref="module_category_ai_features"/>
            <field name="comment">Use Ask-AI, NLQ chat, view own anomaly findings.</field>
        </record>

        <record id="group_ai_admin" model="res.groups">
            <field name="name">AI Features Admin</field>
            <field name="category_id" ref="module_category_ai_features"/>
            <field name="implied_ids" eval="[Command.link(ref('group_ai_user'))]"/>
            <field name="comment">Manage anomaly scans, triage findings, configure scanners.</field>
        </record>

        <!-- Record rule: NLQ sessions belong to one user -->
        <record id="nlq_session_own_rule" model="ir.rule">
            <field name="name">NLQ session: own only</field>
            <field name="model_id" ref="model_ai_nlq_session"/>
            <field name="domain_force">[('user_id','=',user.id)]</field>
            <field name="groups" eval="[Command.link(ref('group_ai_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
        <record id="nlq_session_admin_rule" model="ir.rule">
            <field name="name">NLQ session: admin all</field>
            <field name="model_id" ref="model_ai_nlq_session"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[Command.link(ref('group_ai_admin'))]"/>
        </record>
    </data>
</odoo>
