<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_payroll_id" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.payroll.id</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Payroll Indonesia" name="payroll_id">
                    <group>
                        <group string="Identity">
                            <field name="x_custom_nik"/>
                            <field name="x_custom_npwp"/>
                            <field name="x_custom_kk_no"/>
                            <field name="x_custom_ptkp_status"/>
                            <field name="x_custom_ter_category" readonly="1"/>
                            <field name="x_custom_employment_type"/>
                        </group>
                        <group string="BPJS &amp; Bank">
                            <field name="x_custom_bpjs_kesehatan_no"/>
                            <field name="x_custom_bpjs_tk_no"/>
                            <field name="x_custom_bank_name"/>
                            <field name="x_custom_bank_account"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
