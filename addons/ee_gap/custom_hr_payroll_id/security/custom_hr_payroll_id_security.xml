<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_payroll_id" model="res.groups.privilege">
            <field name="name">Payroll Indonesia</field>
            <field name="sequence">120</field>
            <field name="category_id" ref="custom_core.module_category_custom_platform"/>
        </record>

        <record id="group_user" model="res.groups">
            <field name="name">Payroll ID / Employee</field>
            <field name="privilege_id" ref="res_groups_privilege_payroll_id"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Payroll ID / Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_payroll_id"/>
            <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
