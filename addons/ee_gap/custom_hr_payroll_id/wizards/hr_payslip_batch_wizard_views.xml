<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_batch_wizard" model="ir.ui.view">
        <field name="name">hr.payslip.batch.wizard.form</field>
        <field name="model">hr.payslip.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Payroll Run">
                <sheet>
                    <group invisible="run_done">
                        <group>
                            <field name="period_year"/>
                            <field name="period_month"/>
                            <field name="is_thr"/>
                        </group>
                        <group>
                            <field name="auto_approve"/>
                            <field name="skip_if_exists"/>
                        </group>
                    </group>
                    <group invisible="run_done">
                        <field name="employee_ids" widget="many2many_tags"
                               placeholder="Empty = all active employees in this company"/>
                    </group>
                    <group invisible="not run_done">
                        <field name="summary" widget="html"/>
                        <field name="payslip_ids" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run" string="Run" type="object" class="btn-primary"
                            invisible="run_done"/>
                    <button name="action_open_generated" string="Open Generated" type="object"
                            class="btn-primary" invisible="not run_done"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_payslip_batch_wizard" model="ir.actions.act_window">
        <field name="name">Run Batch Payroll</field>
        <field name="res_model">hr.payslip.batch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
