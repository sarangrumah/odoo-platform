<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_spt_a1_wizard" model="ir.ui.view">
        <field name="name">hr.payroll.spt.a1.wizard.form</field>
        <field name="model">hr.payroll.spt.a1.wizard</field>
        <field name="arch" type="xml">
            <form string="SPT 1721 A1">
                <sheet>
                    <group invisible="run_done">
                        <field name="fiscal_year"/>
                        <field name="output_format"/>
                        <field name="employee_ids" widget="many2many_tags"/>
                    </group>
                    <group invisible="not run_done">
                        <field name="xml_attachment_id" readonly="1"/>
                    </group>
                    <field name="summary_html" widget="html" invisible="not run_done"/>
                </sheet>
                <footer>
                    <button name="action_run" string="Generate" type="object" class="btn-primary"
                            invisible="run_done"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_spt_a1_wizard" model="ir.actions.act_window">
        <field name="name">Generate SPT 1721 A1</field>
        <field name="res_model">hr.payroll.spt.a1.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
