<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appointment_booking_list" model="ir.ui.view">
        <field name="name">appointment.booking.list</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'"
                  decoration-warning="state == 'pending'"
                  decoration-muted="state in ('cancelled','done','no_show')">
                <field name="name"/>
                <field name="type_id"/>
                <field name="resource_id"/>
                <field name="customer_name"/>
                <field name="start_dt"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_appointment_booking_form" model="ir.ui.view">
        <field name="name">appointment.booking.form</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_no_show" string="No-show" type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('cancelled','done','no_show')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="type_id"/>
                            <field name="resource_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="start_dt"/>
                            <field name="end_dt"/>
                            <field name="calendar_event_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Customer">
                        <group>
                            <field name="customer_name"/>
                            <field name="customer_email"/>
                            <field name="customer_phone"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_appointment_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">appointment.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
