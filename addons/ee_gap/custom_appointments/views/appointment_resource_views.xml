<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appointment_resource_list" model="ir.ui.view">
        <field name="name">appointment.resource.list</field>
        <field name="model">appointment.resource</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="user_id"/>
                <field name="capacity"/>
                <field name="working_hours_start"/>
                <field name="working_hours_end"/>
                <field name="working_days"/>
                <field name="timezone"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_appointment_resource" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">appointment.resource</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
