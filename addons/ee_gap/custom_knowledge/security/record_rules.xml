<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            READ rule:
            - admin/manager: always
            - owner: always
            - published article: always (intranet-published)
            - restricted via read_group_ids: only members of those groups
            - if read_group_ids empty: all knowledge users may read
        -->
        <record id="rule_knowledge_article_read" model="ir.rule">
            <field name="name">Knowledge Article: read</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="domain_force">[
                '|', '|', '|',
                    ('owner_id', '=', user.id),
                    ('is_published', '=', True),
                    ('read_group_ids', '=', False),
                    ('read_group_ids', 'in', [g.id for g in user.group_ids]),
            ]</field>
            <field name="groups" eval="[(4, ref('custom_knowledge.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            WRITE rule:
            - owner can write
            - members of group_manager can write everything
            - everyone else: blocked
        -->
        <record id="rule_knowledge_article_write" model="ir.rule">
            <field name="name">Knowledge Article: write</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="domain_force">[('owner_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_knowledge.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Manager bypass: see everything, write everything -->
        <record id="rule_knowledge_article_manager_all" model="ir.rule">
            <field name="name">Knowledge Article: manager all</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('custom_knowledge.group_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Version snapshots inherit access through their parent article -->
        <record id="rule_knowledge_article_version_user" model="ir.rule">
            <field name="name">Knowledge Article Version: read own articles</field>
            <field name="model_id" ref="model_knowledge_article_version"/>
            <field name="domain_force">[
                '|',
                    ('article_id.owner_id', '=', user.id),
                    ('article_id.is_published', '=', True),
            ]</field>
            <field name="groups" eval="[(4, ref('custom_knowledge.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_knowledge_article_version_manager" model="ir.rule">
            <field name="name">Knowledge Article Version: manager all</field>
            <field name="model_id" ref="model_knowledge_article_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('custom_knowledge.group_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
