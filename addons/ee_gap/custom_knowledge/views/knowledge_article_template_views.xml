<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_knowledge_article_template_list" model="ir.ui.view">
        <field name="name">knowledge.article.template.list</field>
        <field name="model">knowledge.article.template</field>
        <field name="arch" type="xml">
            <list string="Templates">
                <field name="name"/>
                <field name="category"/>
                <field name="description"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_knowledge_article_template_form" model="ir.ui.view">
        <field name="name">knowledge.article.template.form</field>
        <field name="model">knowledge.article.template</field>
        <field name="arch" type="xml">
            <form string="Article Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template name..."/></h1>
                    </div>
                    <group>
                        <field name="category"/>
                        <field name="description"/>
                        <field name="is_active"/>
                    </group>
                    <notebook>
                        <page string="Body Template">
                            <field name="body_template"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_knowledge_article_template_search" model="ir.ui.view">
        <field name="name">knowledge.article.template.search</field>
        <field name="model">knowledge.article.template</field>
        <field name="arch" type="xml">
            <search string="Templates">
                <field name="name"/>
                <field name="category"/>
                <filter name="active_only" string="Active"
                        domain="[('is_active','=',True)]"/>
                <separator/>
                <filter name="group_category" string="Category"
                        context="{'group_by':'category'}"/>
            </search>
        </field>
    </record>

    <record id="action_knowledge_article_template" model="ir.actions.act_window">
        <field name="name">Article Templates</field>
        <field name="res_model">knowledge.article.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_knowledge_article_template_search"/>
    </record>
</odoo>
