<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Minimal public renderer for /knowledge/share/<token>. -->
    <template id="portal_share_article" name="Knowledge: Shared Article">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title t-esc="article.name or 'Knowledge'"/>
                <style>
                    body { font-family: -apple-system, system-ui, sans-serif;
                           max-width: 820px; margin: 2em auto; padding: 0 1em;
                           color: #222; line-height: 1.5; }
                    header { border-bottom: 1px solid #eee; padding-bottom: 0.5em;
                             margin-bottom: 1.5em; }
                    h1 { margin: 0 0 0.25em 0; }
                    .meta { color: #888; font-size: 0.9em; }
                    .article-body img { max-width: 100%; height: auto; }
                    footer { margin-top: 3em; border-top: 1px solid #eee;
                             padding-top: 1em; color: #aaa; font-size: 0.8em; }
                </style>
            </head>
            <body>
                <header>
                    <h1 t-esc="article.name"/>
                    <div class="meta">
                        Shared by <t t-esc="article.owner_id.name or 'unknown'"/>
                    </div>
                </header>
                <div class="article-body">
                    <t t-out="article.body"/>
                </div>
                <footer>This is a shared view. The link can be revoked by the owner at any time.</footer>
            </body>
        </html>
    </template>
</odoo>
