<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_asset" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.asset_from_receipt</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_fixed_assets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bank"
                        invisible="fixed_asset_count == 0">
                    <field name="fixed_asset_count" widget="statinfo" string="Fixed Assets"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
