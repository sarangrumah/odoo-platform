<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_asset" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.asset_from_receipt</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="has_rental_asset_lines" invisible="1"/>
                <button name="action_open_asset_conversion_wizard"
                        type="object"
                        string="Convert to Assets"
                        class="btn-primary"
                        invisible="not has_rental_asset_lines"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="fixed_asset_count" invisible="1"/>
                <button name="action_view_fixed_assets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bank"
                        invisible="fixed_asset_count == 0">
                    <field name="fixed_asset_count" widget="statinfo" string="Fixed Assets"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
