<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_asset" model="ir.ui.view">
        <field name="name">product.template.form.inherit.asset_from_receipt</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase']" position="inside">
                <group string="Fixed Asset Provisioning">
                    <field name="is_rental_asset"/>
                    <field name="asset_group_id"
                           invisible="not is_rental_asset"
                           required="is_rental_asset"/>
                    <field name="auto_create_rental_asset"
                           invisible="not is_rental_asset"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
