<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top-level app menu -->
    <menuitem id="menu_dashboards_root"
              name="Dashboards"
              sequence="58"
              web_icon="custom_dashboards,static/description/icon.png"
              groups="custom_dashboards.group_user"/>

    <menuitem id="menu_dashboards_list"
              name="Dashboards"
              parent="menu_dashboards_root"
              action="action_custom_dashboard"
              sequence="10"/>

    <menuitem id="menu_dashboards_new_tile"
              name="New Tile (Wizard)"
              parent="menu_dashboards_root"
              action="action_custom_dashboard_tile_wizard"
              sequence="20"/>

    <menuitem id="menu_dashboards_config"
              name="Configuration"
              parent="menu_dashboards_root"
              sequence="90"
              groups="custom_dashboards.group_manager"/>

    <menuitem id="menu_dashboards_tiles"
              name="All Tiles"
              parent="menu_dashboards_config"
              action="action_custom_dashboard_tile"
              sequence="10"/>

    <!-- Also mount under Custom root -->
    <menuitem id="menu_dashboards_in_custom"
              name="Dashboards"
              parent="custom_core.menu_custom_root"
              action="action_custom_dashboard"
              sequence="45"
              groups="custom_dashboards.group_user"/>
</odoo>
