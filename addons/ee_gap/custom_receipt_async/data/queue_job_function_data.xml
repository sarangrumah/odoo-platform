<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        The vendored queue_job ships empty data files (see
        addons/_vendor/queue_job/data/queue_data.xml). We bootstrap the
        canonical 'root' channel here using the queue_job module namespace so
        anyone calling self.env.ref('queue_job.channel_root') keeps working.
    -->
    <record id="queue_job.channel_root" model="queue.job.channel">
        <field name="name">root</field>
    </record>

    <record id="channel_stock_receipt" model="queue.job.channel">
        <field name="name">stock_receipt</field>
        <field name="parent_id" ref="queue_job.channel_root"/>
    </record>

    <record id="job_function_validate_picking" model="queue.job.function">
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="method">_job_validate_picking</field>
        <field name="channel_id" ref="channel_stock_receipt"/>
    </record>
</odoo>
