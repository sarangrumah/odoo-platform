<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top-level app menu -->
    <menuitem id="menu_helpdesk_root"
              name="Helpdesk"
              sequence="55"
              web_icon="custom_helpdesk,static/description/icon.png"
              groups="custom_helpdesk.group_user"/>

    <menuitem id="menu_helpdesk_tickets"
              name="Tickets"
              parent="menu_helpdesk_root"
              action="action_helpdesk_ticket"
              sequence="10"/>

    <menuitem id="menu_helpdesk_config"
              name="Configuration"
              parent="menu_helpdesk_root"
              sequence="90"
              groups="custom_helpdesk.group_manager"/>

    <menuitem id="menu_helpdesk_teams"
              name="Teams"
              parent="menu_helpdesk_config"
              action="action_helpdesk_team"
              sequence="10"/>

    <menuitem id="menu_helpdesk_sla"
              name="SLA Policies"
              parent="menu_helpdesk_config"
              action="action_helpdesk_sla"
              sequence="20"/>

    <menuitem id="menu_helpdesk_tags"
              name="Tags"
              parent="menu_helpdesk_config"
              action="action_helpdesk_tag"
              sequence="30"/>

    <!-- Also mount under Custom root -->
    <menuitem id="menu_helpdesk_in_custom"
              name="Helpdesk"
              parent="custom_core.menu_custom_root"
              action="action_helpdesk_ticket"
              sequence="40"
              groups="custom_helpdesk.group_user"/>
</odoo>
