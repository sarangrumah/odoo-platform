<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_tag_list" model="ir.ui.view">
        <field name="name">helpdesk.tag.list</field>
        <field name="model">helpdesk.tag</field>
        <field name="arch" type="xml">
            <list string="Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_helpdesk_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">helpdesk.tag</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
