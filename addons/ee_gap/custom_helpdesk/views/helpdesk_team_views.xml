<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_team_list" model="ir.ui.view">
        <field name="name">helpdesk.team.list</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <list string="Teams">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="default_priority"/>
                <field name="sla_id"/>
                <field name="ticket_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_team_form" model="ir.ui.view">
        <field name="name">helpdesk.team.form</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <form string="Team">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Team name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="default_priority"/>
                            <field name="sla_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="alias_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_team" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">helpdesk.team</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
