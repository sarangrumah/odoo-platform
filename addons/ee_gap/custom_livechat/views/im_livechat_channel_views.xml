<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_im_livechat_channel_form_skill" model="ir.ui.view">
        <field name="name">im_livechat.channel.form.skill</field>
        <field name="model">im_livechat.channel</field>
        <field name="inherit_id" ref="im_livechat.im_livechat_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Skill Routing" name="skill_routing">
                    <field name="x_skill_tags"
                           placeholder="billing, refund, technical"
                           help="Comma-separated tag list used for skill-based operator routing."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
