<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appraisal_tpl_list" model="ir.ui.view">
        <field name="name">appraisal.template.list</field>
        <field name="model">appraisal.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_appraisal_tpl_form" model="ir.ui.view">
        <field name="name">appraisal.template.form</field>
        <field name="model">appraisal.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <separator string="Description"/>
                    <field name="description"/>
                    <separator string="Items"/>
                    <field name="item_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="competency"/>
                            <field name="weight"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_appraisal_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">appraisal.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
