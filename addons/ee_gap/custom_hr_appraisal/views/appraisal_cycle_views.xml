<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appraisal_cycle_list" model="ir.ui.view">
        <field name="name">appraisal.cycle.list</field>
        <field name="model">appraisal.cycle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="template_id"/>
                <field name="appraisal_count"/>
                <field name="completed_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_appraisal_cycle_form" model="ir.ui.view">
        <field name="name">appraisal.cycle.form</field>
        <field name="model">appraisal.cycle</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_launch" string="Launch" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'running'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                        </group>
                        <group>
                            <field name="appraisal_count" readonly="1"/>
                            <field name="completed_count" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Departments (empty = all)"/>
                    <field name="department_ids" widget="many2many_tags"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_appraisal_cycle" model="ir.actions.act_window">
        <field name="name">Cycles</field>
        <field name="res_model">appraisal.cycle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
