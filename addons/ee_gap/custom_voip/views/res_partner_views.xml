<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_voip" model="ir.ui.view">
        <field name="name">res.partner.form.voip</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_voip_calls" type="object"
                        class="oe_stat_button" icon="fa-phone">
                    <field name="x_custom_voip_call_count" widget="statinfo" string="Calls"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='phone']" position="after">
                <button name="action_voip_call" type="object" string="📞 Call"
                        class="btn-link" invisible="not phone and not mobile"/>
            </xpath>
        </field>
    </record>
</odoo>
