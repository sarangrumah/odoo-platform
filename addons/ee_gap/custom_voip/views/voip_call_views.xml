<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voip_call_list" model="ir.ui.view">
        <field name="name">voip.call.list</field>
        <field name="model">voip.call</field>
        <field name="arch" type="xml">
            <list decoration-success="outcome == 'answered'"
                  decoration-warning="outcome in ('missed','voicemail')"
                  decoration-danger="outcome in ('busy','failed')">
                <field name="started_at"/>
                <field name="direction"/>
                <field name="partner_id"/>
                <field name="other_number"/>
                <field name="user_id"/>
                <field name="duration_seconds"/>
                <field name="outcome" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_voip_call_form" model="ir.ui.view">
        <field name="name">voip.call.form</field>
        <field name="model">voip.call</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_answered" string="Answered" type="object" class="btn-success"
                            invisible="outcome"/>
                    <button name="action_mark_missed" string="Missed" type="object"
                            invisible="outcome"/>
                    <button name="action_end" string="End Call" type="object"
                            invisible="ended_at"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="provider_id"/>
                            <field name="direction"/>
                            <field name="partner_id"/>
                            <field name="other_number"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="started_at"/>
                            <field name="ended_at"/>
                            <field name="duration_seconds" readonly="1"/>
                            <field name="outcome"/>
                            <field name="recording_url"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_voip_call" model="ir.actions.act_window">
        <field name="name">Call Log</field>
        <field name="res_model">voip.call</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
