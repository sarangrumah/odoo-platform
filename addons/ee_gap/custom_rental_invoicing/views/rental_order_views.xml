<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_order_form_inherit_invoicing" model="ir.ui.view">
        <field name="name">rental.order.form.invoicing</field>
        <field name="model">rental.order</field>
        <field name="inherit_id" ref="custom_rental.view_rental_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_return']" position="after">
                <button name="action_create_invoice" string="Create Invoice" type="object"
                        class="btn-primary"
                        invisible="invoice_id or state not in ('picked_up', 'returned')"/>
            </xpath>
            <xpath expr="//group[@name='settlement']/field[@name='total_due']" position="after">
                <field name="invoice_id" readonly="1"/>
                <field name="invoice_state" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
