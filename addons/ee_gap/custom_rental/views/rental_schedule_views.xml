<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_rental_schedule_list" model="ir.ui.view">
        <field name="name">custom.rental.schedule.list</field>
        <field name="model">custom.rental.schedule</field>
        <field name="arch" type="xml">
            <list create="false" edit="false"
                  decoration-info="state == 'confirmed'"
                  decoration-success="state == 'picked_up'"
                  decoration-danger="state == 'late'"
                  decoration-muted="state in ('returned','cancelled')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_id"/>
                <field name="product_id" optional="hide"/>
                <field name="date_start"/>
                <field name="date_stop"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_custom_rental_schedule_calendar" model="ir.ui.view">
        <field name="name">custom.rental.schedule.calendar</field>
        <field name="model">custom.rental.schedule</field>
        <field name="arch" type="xml">
            <calendar string="Rental Schedule"
                      date_start="date_start"
                      date_stop="date_stop"
                      color="asset_id"
                      mode="month"
                      quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>
    <record id="view_custom_rental_schedule_kanban" model="ir.ui.view">
        <field name="name">custom.rental.schedule.kanban</field>
        <field name="model">custom.rental.schedule</field>
        <field name="arch" type="xml">
            <kanban create="false" default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_id"/>
                <field name="date_start"/>
                <field name="date_stop"/>
                <templates>
                    <t t-name="card">
                        <div>
                            <strong><field name="name"/></strong>
                            <div><field name="partner_id"/></div>
                            <div><field name="asset_id"/></div>
                            <div>
                                <field name="date_start"/> -
                                <field name="date_stop"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_custom_rental_schedule_search" model="ir.ui.view">
        <field name="name">custom.rental.schedule.search</field>
        <field name="model">custom.rental.schedule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_id"/>
                <filter name="active" string="Active"
                        domain="[('state','in',['confirmed','picked_up','late'])]"/>
                <filter name="late" string="Late"
                        domain="[('state','=','late')]"/>

                    <filter name="g_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="g_asset" string="Asset" context="{'group_by':'asset_id'}"/>

            </search>
        </field>
    </record>
    <record id="action_custom_rental_schedule" model="ir.actions.act_window">
        <field name="name">Rental Schedule</field>
        <field name="res_model">custom.rental.schedule</field>
        <field name="view_mode">calendar,kanban,list</field>
    </record>
</odoo>
