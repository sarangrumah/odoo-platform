<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_menu_rental"
              name="Portal layout: rental menu entry"
              inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'rental' or rental_order"
                t-attf-class="breadcrumb-item #{'active ' if not rental_order else ''}">
                <a t-if="rental_order" t-attf-href="/my/rentals?{{ keep_query() }}">Rentals</a>
                <t t-else="">Rentals</t>
            </li>
            <li t-if="rental_order" class="breadcrumb-item active">
                <t t-out="rental_order.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_rental"
              name="Show Rentals on Portal Home"
              inherit_id="portal.portal_my_home"
              customize_show="True" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Rentals</t>
                <t t-set="url" t-value="'/my/rentals'"/>
                <t t-set="placeholder_count" t-value="'rental_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_rentals" name="My Rentals">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <h3 class="mt-3">My Rentals</h3>
            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Reference</th>
                        <th>Pickup</th>
                        <th>Return</th>
                        <th>State</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="rentals" t-as="r">
                        <td><a t-attf-href="/my/rentals/#{r.id}"><t t-out="r.name"/></a></td>
                        <td><t t-out="r.pickup_dt"/></td>
                        <td><t t-out="r.return_dt_expected"/></td>
                        <td><span class="badge text-bg-info" t-out="r.state"/></td>
                        <td class="text-end">
                            <t t-out="r.total_due"
                               t-options='{"widget": "monetary", "display_currency": r.currency_id}'/>
                        </td>
                    </tr>
                </tbody>
            </t>
            <div t-if="pager">
                <t t-call="portal.pager"/>
            </div>
        </t>
    </template>

    <template id="portal_my_rental_detail" name="Rental Detail">
        <t t-call="portal.portal_layout">
            <div class="row">
                <div class="col-12">
                    <h3>Rental <t t-out="order.name"/></h3>
                    <p>
                        <strong>Asset:</strong> <t t-out="order.asset_id.name"/><br/>
                        <strong>Pickup:</strong> <t t-out="order.pickup_dt"/><br/>
                        <strong>Return:</strong> <t t-out="order.return_dt_expected"/><br/>
                        <strong>State:</strong> <t t-out="order.state"/><br/>
                        <strong>Total Due:</strong>
                        <t t-out="order.total_due"
                           t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                    </p>
                    <p>
                        <a t-attf-href="/my/rentals/#{order.id}?report_type=pdf"
                           class="btn btn-primary">Download Contract (PDF)</a>
                    </p>
                    <div class="o_custom_rental_signature_panel" t-att-data-order-id="order.id">
                        <h4>Customer Signature</h4>
                        <canvas class="o_custom_rental_signature_canvas"
                                width="400" height="150"
                                style="border:1px solid #ccc;"></canvas>
                        <div class="mt-2">
                            <input type="text" class="form-control mb-2 o_custom_rental_signed_by"
                                   placeholder="Signed by" style="max-width:400px;"/>
                            <button type="button" class="btn btn-secondary o_custom_rental_signature_clear">Clear</button>
                            <button type="button" class="btn btn-primary o_custom_rental_signature_save">Save</button>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
