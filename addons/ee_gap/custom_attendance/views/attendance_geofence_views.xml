<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_geofence_list" model="ir.ui.view">
        <field name="name">attendance.geofence.list</field>
        <field name="model">attendance.geofence</field>
        <field name="arch" type="xml">
            <list string="Geofences">
                <field name="name"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="radius_meters"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_attendance_geofence_form" model="ir.ui.view">
        <field name="name">attendance.geofence.form</field>
        <field name="model">attendance.geofence</field>
        <field name="arch" type="xml">
            <form string="Geofence">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. HQ Jakarta"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="radius_meters"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_attendance_geofence_search" model="ir.ui.view">
        <field name="name">attendance.geofence.search</field>
        <field name="model">attendance.geofence</field>
        <field name="arch" type="xml">
            <search string="Geofences">
                <field name="name"/>
                <field name="company_id"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_attendance_geofence" model="ir.actions.act_window">
        <field name="name">Geofences</field>
        <field name="res_model">attendance.geofence</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_attendance_geofence_search"/>
    </record>
</odoo>
