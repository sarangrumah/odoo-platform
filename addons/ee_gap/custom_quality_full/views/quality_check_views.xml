<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quality_check_list" model="ir.ui.view">
        <field name="name">quality.check.list</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'pass'"
                  decoration-danger="state == 'fail'"
                  decoration-info="state == 'waiting'">
                <field name="name"/>
                <field name="point_id"/>
                <field name="product_id"/>
                <field name="check_kind"/>
                <field name="user_id"/>
                <field name="state" widget="badge"/>
                <field name="performed_at"/>
                <field name="alert_id"/>
            </list>
        </field>
    </record>
    <record id="view_quality_check_form" model="ir.ui.view">
        <field name="name">quality.check.form</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_pass" string="Pass" type="object" class="btn-success"
                            invisible="state != 'waiting'"/>
                    <button name="action_fail" string="Fail" type="object" class="btn-danger"
                            invisible="state != 'waiting'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="point_id"/>
                            <field name="product_id" readonly="1"/>
                            <field name="check_kind" readonly="1"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="performed_at" readonly="1"/>
                            <field name="alert_id" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="check_kind != 'measure'">
                        <field name="measure_value"/>
                        <field name="measure_uom_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Inspection Lines">
                            <field name="inspection_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question"/>
                                    <field name="response_type"/>
                                    <field name="is_required"/>
                                    <field name="expected_min"/>
                                    <field name="expected_max"/>
                                    <field name="expected_set" optional="hide"/>
                                    <field name="actual_value"/>
                                    <field name="pass_fail" widget="badge" readonly="1"/>
                                </list>
                            </field>
                            <group>
                                <field name="overall_result" readonly="1"/>
                            </group>
                        </page>
                        <page string="Signatures">
                            <field name="signature_ids">
                                <list>
                                    <field name="signer_name"/>
                                    <field name="purpose"/>
                                    <field name="signed_at"/>
                                    <field name="is_valid" widget="boolean_toggle" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_quality_check" model="ir.actions.act_window">
        <field name="name">Checks</field>
        <field name="res_model">quality.check</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
