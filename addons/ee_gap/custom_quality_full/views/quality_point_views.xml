<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quality_point_list" model="ir.ui.view">
        <field name="name">quality.point.list</field>
        <field name="model">quality.point</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="operation"/>
                <field name="check_kind"/>
                <field name="frequency"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_quality_point_form" model="ir.ui.view">
        <field name="name">quality.point.form</field>
        <field name="model">quality.point</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="operation"/>
                            <field name="check_kind"/>
                            <field name="frequency"/>
                        </group>
                        <group invisible="check_kind != 'measure'">
                            <field name="measure_min"/>
                            <field name="measure_max"/>
                            <field name="measure_uom_id"/>
                        </group>
                    </group>
                    <separator string="Instructions"/>
                    <field name="instructions"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_quality_point" model="ir.actions.act_window">
        <field name="name">Control Points</field>
        <field name="res_model">quality.point</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
