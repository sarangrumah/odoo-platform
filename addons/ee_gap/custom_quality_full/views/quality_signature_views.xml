<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_quality_signature_list" model="ir.ui.view">
        <field name="name">custom.quality.signature.list</field>
        <field name="model">custom.quality.signature</field>
        <field name="arch" type="xml">
            <list>
                <field name="signed_at"/>
                <field name="signer_name"/>
                <field name="purpose"/>
                <field name="check_id"/>
                <field name="capa_id"/>
                <field name="is_valid" widget="boolean_toggle" readonly="1"/>
            </list>
        </field>
    </record>
    <record id="view_custom_quality_signature_form" model="ir.ui.view">
        <field name="name">custom.quality.signature.form</field>
        <field name="model">custom.quality.signature</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="signer_id"/>
                            <field name="signer_name"/>
                            <field name="signer_email"/>
                            <field name="purpose"/>
                            <field name="signed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="check_id"/>
                            <field name="capa_id"/>
                            <field name="hash" readonly="1"/>
                            <field name="is_valid" widget="boolean_toggle" readonly="1"/>
                        </group>
                    </group>
                    <field name="image" widget="image"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
