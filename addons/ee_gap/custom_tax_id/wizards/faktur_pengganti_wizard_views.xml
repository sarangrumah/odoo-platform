<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_faktur_pengganti_wizard" model="ir.ui.view">
        <field name="name">tax.faktur.pengganti.wizard.form</field>
        <field name="model">tax.faktur.pengganti.wizard</field>
        <field name="arch" type="xml">
            <form string="Faktur Pengganti">
                <sheet>
                    <group>
                        <field name="source_move_id" options="{'no_create': True}"/>
                        <field name="new_invoice_date"/>
                        <field name="next_kode_status"/>
                        <field name="keep_lines"/>
                    </group>
                    <separator string="Reason"/>
                    <field name="reason" placeholder="e.g. Salah NPWP pembeli; nominal koreksi atas faktur 0123..."/>
                </sheet>
                <footer>
                    <button name="action_create_replacement"
                            string="Create Replacement"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_faktur_pengganti_wizard" model="ir.actions.act_window">
        <field name="name">Faktur Pengganti</field>
        <field name="res_model">tax.faktur.pengganti.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
