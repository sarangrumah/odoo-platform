<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_tax_id" model="ir.ui.view">
        <field name="name">product.template.form.tax_id</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase']" position="after">
                <page string="PPh Withholding">
                    <group>
                        <field name="x_custom_withholding_category_id"/>
                    </group>
                    <p class="text-muted">
                        If set, vendor bill lines on this product will default to this PPh
                        category — useful for jasa konsultan, sewa, royalti, dan jasa lainnya.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
