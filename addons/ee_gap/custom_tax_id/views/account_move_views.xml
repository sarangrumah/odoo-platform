<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_form_withholding" model="ir.ui.view">
        <field name="name">account.move.form.withholding</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="PPh Withholding"
                      invisible="move_type not in ('in_invoice','in_refund')">
                    <field name="x_custom_withholding_line_ids" readonly="1">
                        <list create="0" delete="0">
                            <field name="category_id"/>
                            <field name="pph_kind"/>
                            <field name="base_amount"/>
                            <field name="tarif"/>
                            <field name="tax_amount"/>
                            <field name="bupot_id"/>
                        </list>
                    </field>
                    <group>
                        <field name="x_custom_total_withheld"/>
                    </group>
                </page>
                <page string="Faktur Pengganti"
                      invisible="move_type not in ('out_invoice','out_refund')">
                    <group>
                        <field name="x_custom_coretax_kode_status"/>
                        <field name="x_custom_coretax_replacement_of_id"/>
                        <field name="x_custom_coretax_replaced_by_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
