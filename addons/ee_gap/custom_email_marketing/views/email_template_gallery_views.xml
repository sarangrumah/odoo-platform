<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_email_template_gallery_list" model="ir.ui.view">
        <field name="name">custom.email.template.gallery.list</field>
        <field name="model">custom.email.template.gallery</field>
        <field name="arch" type="xml">
            <list string="Email Templates">
                <field name="name"/>
                <field name="category"/>
                <field name="language_code"/>
                <field name="subject"/>
                <field name="times_used"/>
            </list>
        </field>
    </record>

    <record id="view_email_template_gallery_form" model="ir.ui.view">
        <field name="name">custom.email.template.gallery.form</field>
        <field name="model">custom.email.template.gallery</field>
        <field name="arch" type="xml">
            <form string="Email Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="language_code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="times_used" readonly="1"/>
                            <field name="preview_thumbnail" widget="image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body">
                            <field name="body_html" widget="html"/>
                        </page>
                        <page string="Suggested Lists">
                            <field name="tag_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_email_template_gallery_search" model="ir.ui.view">
        <field name="name">custom.email.template.gallery.search</field>
        <field name="model">custom.email.template.gallery</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="subject"/>
                <field name="category"/>
                <filter name="welcome"
                        domain="[('category','=','welcome')]"/>
                <filter name="newsletter"
                        domain="[('category','=','newsletter')]"/>
                <filter name="promo"
                        domain="[('category','=','promo')]"/>
                <filter name="transactional"
                        domain="[('category','=','transactional')]"/>
                <filter name="reminder"
                        domain="[('category','=','reminder')]"/>
            </search>
        </field>
    </record>

    <record id="action_email_template_gallery" model="ir.actions.act_window">
        <field name="name">Template Gallery</field>
        <field name="res_model">custom.email.template.gallery</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_email_template_gallery_search"/>
    </record>
</odoo>
