<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_email_apply_template_wizard_form" model="ir.ui.view">
        <field name="name">custom.email.apply.template.wizard.form</field>
        <field name="model">custom.email.apply.template.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply Email Template">
                <sheet>
                    <group>
                        <field name="mailing_id" readonly="1"/>
                        <field name="template_id" options="{'no_create': True}"/>
                        <field name="preview_subject" readonly="1"/>
                        <field name="preview_thumbnail" widget="image" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Preview">
                            <field name="preview_body" widget="html" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Apply Template"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
