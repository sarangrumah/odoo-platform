<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Daily generator for recurring journal entries.
        Cron picks up templates with next_run_date <= today and posts the
        scheduled move. Implementation: `custom.recurring.template._cron_generate_entries`.
    -->
    <record id="cron_recurring_generate" model="ir.cron">
        <field name="name">Custom: Generate Recurring Journal Entries</field>
        <field name="model_id" ref="model_custom_recurring_journal_template"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_entries() if hasattr(model, '_cron_generate_entries') else None</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
