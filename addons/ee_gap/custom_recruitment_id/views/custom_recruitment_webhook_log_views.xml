<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_recruitment_webhook_log_list" model="ir.ui.view">
        <field name="name">custom.recruitment.webhook.log.list</field>
        <field name="model">custom.recruitment.webhook.log</field>
        <field name="arch" type="xml">
            <list string="Webhook Logs"
                  decoration-success="processed == True"
                  decoration-danger="processed == False and error_message">
                <field name="received_at"/>
                <field name="source"/>
                <field name="applicant_id"/>
                <field name="processed" widget="boolean_toggle"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_recruitment_webhook_log_form" model="ir.ui.view">
        <field name="name">custom.recruitment.webhook.log.form</field>
        <field name="model">custom.recruitment.webhook.log</field>
        <field name="arch" type="xml">
            <form string="Webhook Log">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="source"/>
                            <field name="received_at"/>
                            <field name="processed"/>
                        </group>
                        <group>
                            <field name="applicant_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload" name="payload">
                            <field name="payload_json" widget="text"/>
                        </page>
                        <page string="Error" name="error" invisible="not error_message">
                            <field name="error_message" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_recruitment_webhook_log_search" model="ir.ui.view">
        <field name="name">custom.recruitment.webhook.log.search</field>
        <field name="model">custom.recruitment.webhook.log</field>
        <field name="arch" type="xml">
            <search string="Webhook Logs">
                <field name="source"/>
                <field name="applicant_id"/>
                <field name="error_message"/>
                <filter string="Processed" name="filter_processed"
                        domain="[('processed', '=', True)]"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('processed', '=', False)]"/>
                <filter string="With Error" name="filter_error"
                        domain="[('error_message', '!=', False)]"/>
                <separator/>
                <filter string="Source" name="group_source" context="{'group_by': 'source'}"/>
                <filter string="Received Date" name="group_received" context="{'group_by': 'received_at:day'}"/>
            </search>
        </field>
    </record>

    <record id="action_recruitment_webhook_log" model="ir.actions.act_window">
        <field name="name">Webhook Logs</field>
        <field name="res_model">custom.recruitment.webhook.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_recruitment_webhook_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No webhook deliveries yet.</p>
            <p>Inbound applications from Jobstreet/Glints/LinkedIn will appear here.</p>
        </field>
    </record>
</odoo>
