<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_template_list" model="ir.ui.view">
        <field name="name">whatsapp.template.list</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Templates"
                  decoration-success="status == 'approved'"
                  decoration-danger="status == 'rejected'"
                  decoration-muted="status == 'draft'">
                <field name="name"/>
                <field name="account_id"/>
                <field name="language_code"/>
                <field name="category"/>
                <field name="variables_count"/>
                <field name="meta_template_id"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_template_form" model="ir.ui.view">
        <field name="name">whatsapp.template.form</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Template">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,pending_review,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. order_shipped_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="account_id"/>
                            <field name="language_code"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="meta_template_id"/>
                            <field name="variables_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body">
                            <field name="body_text"
                                   placeholder="Halo {{1}}, pesanan {{2}} sudah dikirim."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_template_search" model="ir.ui.view">
        <field name="name">whatsapp.template.search</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <search string="WhatsApp Templates">
                <field name="name"/>
                <field name="account_id"/>
                <field name="meta_template_id"/>
                <filter name="approved" string="Approved" domain="[('status','=','approved')]"/>
                <filter name="pending" string="Pending Review" domain="[('status','=','pending_review')]"/>
                <filter name="marketing" string="Marketing" domain="[('category','=','marketing')]"/>
                <separator/>
                <filter name="group_status" string="Status" context="{'group_by':'status'}"/>
                <filter name="group_category" string="Category" context="{'group_by':'category'}"/>
                <filter name="group_account" string="Account" context="{'group_by':'account_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_template" model="ir.actions.act_window">
        <field name="name">WhatsApp Templates</field>
        <field name="res_model">whatsapp.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_whatsapp_template_search"/>
    </record>
</odoo>
