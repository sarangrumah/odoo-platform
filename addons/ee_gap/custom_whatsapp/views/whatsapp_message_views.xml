<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_message_list" model="ir.ui.view">
        <field name="name">whatsapp.message.list</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages"
                  decoration-success="state in ('delivered','read')"
                  decoration-danger="state == 'failed'"
                  decoration-muted="state == 'draft'"
                  decoration-info="direction == 'inbound'">
                <field name="create_date"/>
                <field name="direction"/>
                <field name="account_id"/>
                <field name="template_id"/>
                <field name="to_phone"/>
                <field name="to_partner_id"/>
                <field name="consent_verified" widget="boolean_toggle"/>
                <field name="state" widget="badge"/>
                <field name="sent_at"/>
                <field name="provider_message_id"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_message_form" model="ir.ui.view">
        <field name="name">whatsapp.message.form</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message">
                <header>
                    <button name="action_send" type="object" string="Send"
                            class="oe_highlight"
                            invisible="direction == 'inbound' or state not in ('draft','queued','failed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,queued,sent,delivered,read"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="direction"/>
                            <field name="account_id"/>
                            <field name="template_id"/>
                            <field name="to_partner_id"/>
                            <field name="to_phone"/>
                        </group>
                        <group>
                            <field name="consent_verified"/>
                            <field name="sent_at"/>
                            <field name="provider_message_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body">
                            <field name="body" placeholder="Message body or rendered template..."/>
                        </page>
                        <page string="Error" invisible="state != 'failed'">
                            <field name="error_message"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_message_search" model="ir.ui.view">
        <field name="name">whatsapp.message.search</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <search string="WhatsApp Messages">
                <field name="to_phone"/>
                <field name="to_partner_id"/>
                <field name="account_id"/>
                <field name="template_id"/>
                <field name="provider_message_id"/>
                <filter name="outbound" string="Outbound" domain="[('direction','=','outbound')]"/>
                <filter name="inbound" string="Inbound" domain="[('direction','=','inbound')]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="queued" string="Queued" domain="[('state','=','queued')]"/>
                <filter name="failed" string="Failed" domain="[('state','=','failed')]"/>
                <filter name="no_consent" string="Consent Not Verified"
                        domain="[('consent_verified','=',False)]"/>
                <separator/>
                <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                <filter name="group_direction" string="Direction" context="{'group_by':'direction'}"/>
                <filter name="group_account" string="Account" context="{'group_by':'account_id'}"/>
                <filter name="group_template" string="Template" context="{'group_by':'template_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_message" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_whatsapp_message_search"/>
    </record>
</odoo>
