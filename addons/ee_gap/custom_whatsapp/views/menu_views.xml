<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top-level WhatsApp app menu -->
    <menuitem id="menu_whatsapp_root"
              name="WhatsApp"
              sequence="58"
              groups="custom_whatsapp.group_user"/>

    <menuitem id="menu_whatsapp_messages"
              name="Messages"
              parent="menu_whatsapp_root"
              action="action_whatsapp_message"
              sequence="10"/>

    <menuitem id="menu_whatsapp_templates"
              name="Templates"
              parent="menu_whatsapp_root"
              action="action_whatsapp_template"
              sequence="20"/>

    <menuitem id="menu_whatsapp_config"
              name="Configuration"
              parent="menu_whatsapp_root"
              sequence="90"
              groups="custom_whatsapp.group_manager"/>

    <menuitem id="menu_whatsapp_accounts"
              name="Accounts"
              parent="menu_whatsapp_config"
              action="action_whatsapp_account"
              sequence="10"/>

    <!-- Also mount under Custom root -->
    <menuitem id="menu_whatsapp_in_custom"
              name="WhatsApp"
              parent="custom_core.menu_custom_root"
              action="action_whatsapp_message"
              sequence="45"
              groups="custom_whatsapp.group_user"/>
</odoo>
