<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_bank_import_user" model="res.groups">
            <field name="name">Bank Import User</field>
            <field name="comment">Can run CSV imports and view logs.</field>
        </record>

        <record id="group_bank_import_admin" model="res.groups">
            <field name="name">Bank Import Admin</field>
            <field name="implied_ids" eval="[Command.link(ref('group_bank_import_user'))]"/>
            <field name="comment">Manage templates and H2H credentials.</field>
        </record>
    </data>
</odoo>
