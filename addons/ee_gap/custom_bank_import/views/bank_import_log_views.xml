<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bank_import_log_list" model="ir.ui.view">
        <field name="name">custom.bank.import.log.list</field>
        <field name="model">custom.bank.import.log</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'failed'"
                  decoration-warning="state == 'partial'">
                <field name="imported_at"/>
                <field name="template_id"/>
                <field name="journal_id"/>
                <field name="filename"/>
                <field name="line_count"/>
                <field name="error_count"/>
                <field name="state" widget="badge"/>
                <field name="imported_by_id"/>
            </list>
        </field>
    </record>

    <record id="view_bank_import_log_form" model="ir.ui.view">
        <field name="name">custom.bank.import.log.form</field>
        <field name="model">custom.bank.import.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="journal_id"/>
                            <field name="statement_id"/>
                            <field name="filename"/>
                            <field name="file_hash"/>
                        </group>
                        <group>
                            <field name="imported_at"/>
                            <field name="imported_by_id"/>
                            <field name="state"/>
                            <field name="line_count"/>
                            <field name="error_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Errors / Notes">
                            <field name="error_message"/>
                        </page>
                        <page string="Raw Payload">
                            <field name="raw_payload"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bank_import_log" model="ir.actions.act_window">
        <field name="name">Bank Import Logs</field>
        <field name="res_model">custom.bank.import.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
