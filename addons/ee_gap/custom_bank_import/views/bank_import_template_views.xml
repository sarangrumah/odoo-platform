<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bank_import_template_list" model="ir.ui.view">
        <field name="name">custom.bank.import.template.list</field>
        <field name="model">custom.bank.import.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="bank_id"/>
                <field name="encoding"/>
                <field name="delimiter"/>
                <field name="date_format"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bank_import_template_form" model="ir.ui.view">
        <field name="name">custom.bank.import.template.form</field>
        <field name="model">custom.bank.import.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. BCA Internet Banking CSV"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="bank_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="encoding"/>
                            <field name="delimiter"/>
                            <field name="has_header"/>
                            <field name="date_format"/>
                            <field name="decimal_separator"/>
                            <field name="thousand_separator"/>
                        </group>
                    </group>
                    <group string="Column Mapping (1-based; -1 = unused)">
                        <group>
                            <field name="date_column_index"/>
                            <field name="ref_column_index"/>
                            <field name="partner_column_index"/>
                            <field name="balance_column_index"/>
                        </group>
                        <group>
                            <field name="signed_amount_column_index"
                                   help="If set, this column holds signed amount and overrides credit/debit."/>
                            <field name="amount_credit_column_index"/>
                            <field name="amount_debit_column_index"/>
                        </group>
                    </group>
                    <group string="Sample File">
                        <field name="sample_file" filename="sample_filename"/>
                        <field name="sample_filename" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bank_import_template" model="ir.actions.act_window">
        <field name="name">Bank Import Templates</field>
        <field name="res_model">custom.bank.import.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
