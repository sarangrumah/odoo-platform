<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bank_h2h_list" model="ir.ui.view">
        <field name="name">custom.bank.h2h.connection.list</field>
        <field name="model">custom.bank.h2h.connection</field>
        <field name="arch" type="xml">
            <list decoration-danger="status == 'error'"
                  decoration-muted="status == 'paused'">
                <field name="name"/>
                <field name="bank_code"/>
                <field name="account_number"/>
                <field name="journal_id"/>
                <field name="sync_interval_minutes"/>
                <field name="last_sync_at"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_bank_h2h_form" model="ir.ui.view">
        <field name="name">custom.bank.h2h.connection.form</field>
        <field name="model">custom.bank.h2h.connection</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_now" type="object"
                            string="Sync Now" class="btn-primary"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="bank_code"/>
                            <field name="account_number"/>
                            <field name="journal_id"/>
                        </group>
                        <group>
                            <field name="adapter_config_id"/>
                            <field name="sync_interval_minutes"/>
                            <field name="last_sync_at"/>
                        </group>
                    </group>
                    <group string="Last Error" invisible="not last_error">
                        <field name="last_error" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bank_h2h_connection" model="ir.actions.act_window">
        <field name="name">H2H Connections</field>
        <field name="res_model">custom.bank.h2h.connection</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
