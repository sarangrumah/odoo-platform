<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bank_import_csv_wizard_form" model="ir.ui.view">
        <field name="name">custom.bank.import.csv.wizard.form</field>
        <field name="model">custom.bank.import.csv.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement">
                <group>
                    <field name="journal_id"/>
                    <field name="template_id"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="statement_name"/>
                </group>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bank_import_csv_wizard" model="ir.actions.act_window">
        <field name="name">Import Bank Statement (CSV)</field>
        <field name="res_model">custom.bank.import.csv.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
