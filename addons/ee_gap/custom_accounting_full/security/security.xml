<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_accounting_full" model="ir.module.category">
            <field name="name">Accounting / Group Reporting</field>
            <field name="description">Multi-company accounting + consolidation</field>
            <field name="sequence">80</field>
        </record>

        <record id="group_consolidation_viewer" model="res.groups">
            <field name="name">Consolidation Viewer</field>
        </record>

        <record id="group_consolidation_admin" model="res.groups">
            <field name="name">Consolidation Admin</field>
            <field name="implied_ids" eval="[Command.link(ref('group_consolidation_viewer'))]"/>
        </record>

        <!-- Fiscal Year -->
        <record id="group_fiscal_year_admin" model="res.groups">
            <field name="name">Fiscal Year Admin</field>
            <field name="category_id" ref="module_category_accounting_full"/>
        </record>

        <!-- Reconcile -->
        <record id="group_reconcile_admin" model="res.groups">
            <field name="name">Reconcile Rule Admin</field>
            <field name="category_id" ref="module_category_accounting_full"/>
        </record>

        <!-- Follow-up -->
        <record id="group_followup_admin" model="res.groups">
            <field name="name">Follow-up Admin</field>
            <field name="category_id" ref="module_category_accounting_full"/>
        </record>

        <!-- Credit Limit -->
        <record id="group_credit_limit_admin" model="res.groups">
            <field name="name">Credit Limit Admin</field>
            <field name="category_id" ref="module_category_accounting_full"/>
        </record>

        <!-- 3-Way Match -->
        <record id="group_match_user" model="res.groups">
            <field name="name">3-Way Match User</field>
            <field name="category_id" ref="module_category_accounting_full"/>
        </record>
        <record id="group_match_admin" model="res.groups">
            <field name="name">3-Way Match Admin</field>
            <field name="category_id" ref="module_category_accounting_full"/>
            <field name="implied_ids" eval="[Command.link(ref('group_match_user'))]"/>
        </record>

    </data>
</odoo>
