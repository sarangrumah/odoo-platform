<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_match_policy_list" model="ir.ui.view">
        <field name="name">custom.match.policy.list</field>
        <field name="model">custom.match.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="qty_tolerance_percent"/>
                <field name="price_tolerance_percent"/>
                <field name="on_qty_mismatch"/>
                <field name="on_price_mismatch"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_match_policy_form" model="ir.ui.view">
        <field name="name">custom.match.policy.form</field>
        <field name="model">custom.match.policy</field>
        <field name="arch" type="xml">
            <form string="3-Way Match Policy">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="qty_tolerance_percent"/>
                            <field name="price_tolerance_percent"/>
                            <field name="on_qty_mismatch"/>
                            <field name="on_price_mismatch"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_match_policy" model="ir.actions.act_window">
        <field name="name">3-Way Match Policies</field>
        <field name="res_model">custom.match.policy</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
