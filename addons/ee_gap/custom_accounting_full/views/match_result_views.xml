<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_match_result_list" model="ir.ui.view">
        <field name="name">custom.match.result.list</field>
        <field name="model">custom.match.result</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="move_id"/>
                <field name="overall_status"/>
                <field name="computed_at"/>
            </list>
        </field>
    </record>

    <record id="view_match_result_form" model="ir.ui.view">
        <field name="name">custom.match.result.form</field>
        <field name="model">custom.match.result</field>
        <field name="arch" type="xml">
            <form create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="move_id"/>
                            <field name="overall_status"/>
                            <field name="computed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_results">
                                <list>
                                    <field name="bill_line_id"/>
                                    <field name="po_line_id"/>
                                    <field name="ordered_qty"/>
                                    <field name="received_qty"/>
                                    <field name="billed_qty"/>
                                    <field name="qty_variance_pct"/>
                                    <field name="unit_price_po"/>
                                    <field name="unit_price_bill"/>
                                    <field name="price_variance_pct"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_match_result" model="ir.actions.act_window">
        <field name="name">3-Way Match Results</field>
        <field name="res_model">custom.match.result</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
