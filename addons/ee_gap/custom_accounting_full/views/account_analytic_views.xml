<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_analytic_form_branch" model="ir.ui.view">
        <field name="name">account.analytic.account.form.branch</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Branch (kantor cabang)" name="branch_info">
                    <field name="x_custom_branch_code"/>
                    <field name="x_custom_is_branch_root"/>
                    <field name="x_custom_branch_root_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_account_analytic_list_branch" model="ir.ui.view">
        <field name="name">account.analytic.account.list.branch</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_custom_branch_code" optional="show"/>
                <field name="x_custom_branch_root_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
