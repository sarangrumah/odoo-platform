<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_config_settings_accounting_full" model="ir.ui.view">
        <field name="name">res.config.settings.accounting.full</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[1]" position="before">
                <block title="Group Reporting (Custom)" name="custom_consol_block">
                    <setting id="custom_consol_enable" string="Intercompany Consolidation">
                        <field name="intercompany_consolidation_active"/>
                        <div class="text-muted">
                            Exposes the multi-chart consolidation menu (charts,
                            mappings, elimination rules and proposals).
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
