<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_ic" model="ir.ui.view">
        <field name="name">res.company.form.ic</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Intercompany" name="intercompany_info">
                    <field name="x_custom_ic_enabled"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
