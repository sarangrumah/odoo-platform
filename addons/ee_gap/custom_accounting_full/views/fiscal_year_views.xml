<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fiscal_year_list" model="ir.ui.view">
        <field name="name">custom.fiscal.year.list</field>
        <field name="model">custom.fiscal.year</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'open'" decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="move_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fiscal_year_form" model="ir.ui.view">
        <field name="name">custom.fiscal.year.form</field>
        <field name="model">custom.fiscal.year</field>
        <field name="arch" type="xml">
            <form string="Fiscal Year">
                <header>
                    <button name="action_open" type="object" string="Open"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_open_close_wizard" type="object"
                            string="Close…" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'open'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="move_count"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fiscal_year" model="ir.actions.act_window">
        <field name="name">Fiscal Years</field>
        <field name="res_model">custom.fiscal.year</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
