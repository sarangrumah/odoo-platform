<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ic_rule_list" model="ir.ui.view">
        <field name="name">account.intercompany.rule.list</field>
        <field name="model">account.intercompany.rule</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name"/>
                <field name="company_from_id"/>
                <field name="company_to_id"/>
                <field name="direction"/>
                <field name="target_journal_id"/>
                <field name="auto_validate"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_ic_rule_form" model="ir.ui.view">
        <field name="name">account.intercompany.rule.form</field>
        <field name="model">account.intercompany.rule</field>
        <field name="arch" type="xml">
            <form string="Intercompany Rule">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. PT A → PT B sales mirror"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_from_id"/>
                            <field name="company_to_id"/>
                            <field name="direction"/>
                        </group>
                        <group>
                            <field name="target_journal_id"/>
                            <field name="auto_validate"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Account Mapping">
                            <field name="mapping_ids">
                                <list editable="bottom">
                                    <field name="source_account_id"
                                           options="{'no_create': True}"
                                           domain="[('company_ids', 'in', parent.company_from_id)]"/>
                                    <field name="target_account_id"
                                           options="{'no_create': True}"
                                           domain="[('company_ids', 'in', parent.company_to_id)]"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ic_rule" model="ir.actions.act_window">
        <field name="name">Intercompany Rules</field>
        <field name="res_model">account.intercompany.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
