<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_followup_level_list" model="ir.ui.view">
        <field name="name">custom.followup.level.list</field>
        <field name="model">custom.followup.level</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="delay_days"/>
                <field name="action"/>
                <field name="send_email"/>
                <field name="email_template_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_followup_level_form" model="ir.ui.view">
        <field name="name">custom.followup.level.form</field>
        <field name="model">custom.followup.level</field>
        <field name="arch" type="xml">
            <form string="Follow-up Level">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="delay_days"/>
                            <field name="action"/>
                            <field name="send_email"/>
                            <field name="email_template_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_followup_stat_list" model="ir.ui.view">
        <field name="name">custom.followup.stat.by.partner.list</field>
        <field name="model">custom.followup.stat.by.partner</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="partner_name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="custom_followup_level_id"/>
                <field name="days_overdue"/>
                <field name="overdue_amount" sum="Total Overdue"/>
                <field name="open_invoice_count"/>
            </list>
        </field>
    </record>

    <record id="view_followup_stat_search" model="ir.ui.view">
        <field name="name">custom.followup.stat.by.partner.search</field>
        <field name="model">custom.followup.stat.by.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_name"/>
                <field name="custom_followup_level_id"/>
                <filter name="has_overdue" string="Has Overdue"
                        domain="[('overdue_amount', '&gt;', 0)]"/>
            </search>
        </field>
    </record>

    <record id="action_followup_level" model="ir.actions.act_window">
        <field name="name">Follow-up Levels</field>
        <field name="res_model">custom.followup.level</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_followup_stat" model="ir.actions.act_window">
        <field name="name">Follow-up Statistics</field>
        <field name="res_model">custom.followup.stat.by.partner</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
