<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_elimination_rule_list" model="ir.ui.view">
        <field name="name">custom.elimination.rule.list</field>
        <field name="model">custom.elimination.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="chart_id"/>
                <field name="company_a_id"/>
                <field name="company_b_id"/>
                <field name="account_a_id"/>
                <field name="account_b_id"/>
                <field name="match_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_elimination_rule_form" model="ir.ui.view">
        <field name="name">custom.elimination.rule.form</field>
        <field name="model">custom.elimination.rule</field>
        <field name="arch" type="xml">
            <form string="Elimination Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="chart_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="match_type"/>
                            <field name="partner_id" invisible="match_type != 'by_partner'"/>
                        </group>
                        <group>
                            <field name="company_a_id"/>
                            <field name="account_a_id"/>
                            <field name="company_b_id"/>
                            <field name="account_b_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elimination_rule" model="ir.actions.act_window">
        <field name="name">Elimination Rules</field>
        <field name="res_model">custom.elimination.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
