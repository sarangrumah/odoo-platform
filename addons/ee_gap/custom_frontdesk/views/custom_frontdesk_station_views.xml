<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_frontdesk_station_list" model="ir.ui.view">
        <field name="name">custom.frontdesk.station.list</field>
        <field name="model">custom.frontdesk.station</field>
        <field name="arch" type="xml">
            <list string="Stations">
                <field name="name"/>
                <field name="company_id"/>
                <field name="location_description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_frontdesk_station_form" model="ir.ui.view">
        <field name="name">custom.frontdesk.station.form</field>
        <field name="model">custom.frontdesk.station</field>
        <field name="arch" type="xml">
            <form string="Station">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Lobby A"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="location_description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_frontdesk_station" model="ir.actions.act_window">
        <field name="name">Stations</field>
        <field name="res_model">custom.frontdesk.station</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
