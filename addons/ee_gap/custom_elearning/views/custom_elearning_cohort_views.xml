<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elearning_cohort_list" model="ir.ui.view">
        <field name="name">custom.elearning.cohort.list</field>
        <field name="model">custom.elearning.cohort</field>
        <field name="arch" type="xml">
            <list string="Cohorts" decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="channel_id"/>
                <field name="instructor_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="capacity"/>
                <field name="enrolled_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_elearning_cohort_form" model="ir.ui.view">
        <field name="name">custom.elearning.cohort.form</field>
        <field name="model">custom.elearning.cohort</field>
        <field name="arch" type="xml">
            <form string="Cohort">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,open,running,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Cohort name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="channel_id"/>
                            <field name="instructor_id"/>
                            <field name="capacity"/>
                            <field name="enrolled_count"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_elearning_cohort_search" model="ir.ui.view">
        <field name="name">custom.elearning.cohort.search</field>
        <field name="model">custom.elearning.cohort</field>
        <field name="arch" type="xml">
            <search string="Cohorts">
                <field name="name"/>
                <field name="channel_id"/>
                <field name="instructor_id"/>
                <field name="member_ids"/>
                <filter name="open_state" string="Open"
                        domain="[('state','in',('open','running'))]"/>
                <filter name="completed" string="Completed"
                        domain="[('state','=','completed')]"/>
                <filter name="my_cohorts" string="My Cohorts"
                        domain="[('instructor_id','=',uid)]"/>
                <separator/>
                <filter name="group_channel" string="Course" context="{'group_by':'channel_id'}"/>
                <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                <filter name="group_instructor" string="Instructor" context="{'group_by':'instructor_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_elearning_cohort" model="ir.actions.act_window">
        <field name="name">Cohorts</field>
        <field name="res_model">custom.elearning.cohort</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_elearning_cohort_search"/>
    </record>
</odoo>
