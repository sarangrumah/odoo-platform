<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_fleet_driver_assignment_list" model="ir.ui.view">
        <field name="name">custom.fleet.driver.assignment.list</field>
        <field name="model">custom.fleet.driver.assignment</field>
        <field name="arch" type="xml">
            <list string="Driver Assignments"
                  decoration-success="status == 'active'"
                  decoration-muted="status == 'ended'"
                  decoration-info="status == 'transferred'">
                <field name="vehicle_id"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration_days"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-muted="status == 'ended'"
                       decoration-info="status == 'transferred'"/>
            </list>
        </field>
    </record>

    <record id="view_custom_fleet_driver_assignment_form" model="ir.ui.view">
        <field name="name">custom.fleet.driver.assignment.form</field>
        <field name="model">custom.fleet.driver.assignment</field>
        <field name="arch" type="xml">
            <form string="Driver Assignment">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="partner_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_days"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_custom_fleet_driver_assignment_search" model="ir.ui.view">
        <field name="name">custom.fleet.driver.assignment.search</field>
        <field name="model">custom.fleet.driver.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="vehicle_id"/>
                <field name="partner_id"/>
                <filter name="active" string="Active"
                        domain="[('status', '=', 'active')]"/>
                <filter name="ended" string="Ended"
                        domain="[('status', '=', 'ended')]"/>
                <separator/>
                <filter name="group_vehicle" string="Vehicle"
                        context="{'group_by': 'vehicle_id'}"/>
                <filter name="group_partner" string="Driver"
                        context="{'group_by': 'partner_id'}"/>
                <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <record id="action_custom_fleet_driver_assignment" model="ir.actions.act_window">
        <field name="name">Driver Assignments</field>
        <field name="res_model">custom.fleet.driver.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_custom_fleet_driver_assignment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Driver assignment history is maintained automatically as the assigned driver changes on a vehicle.
            </p>
        </field>
    </record>
</odoo>
