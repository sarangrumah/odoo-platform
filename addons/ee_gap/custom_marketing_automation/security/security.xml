        <record id="group_marketing_manager" model="res.groups">
            <field name="name">Marketing Manager</field>
            <field name="category_id" ref="module_category_marketing"/>
            <field name="implied_ids" eval="[Command.link(ref('group_marketing_user'))]"/>
        </record>
    </data>
</odoo>
