<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_marketing_segment_list" model="ir.ui.view">
        <field name="name">marketing.segment.list</field>
        <field name="model">marketing.segment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_id"/>
                <field name="contact_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_marketing_segment_form" model="ir.ui.view">
        <field name="name">marketing.segment.form</field>
        <field name="model">marketing.segment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <field name="model_id"/>
                        <field name="filter_domain" widget="domain"
                               options="{'model': 'model_id', 'in_dialog': True}"/>
                        <field name="contact_count" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_marketing_segment" model="ir.actions.act_window">
        <field name="name">Audience Segments</field>
        <field name="res_model">marketing.segment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
