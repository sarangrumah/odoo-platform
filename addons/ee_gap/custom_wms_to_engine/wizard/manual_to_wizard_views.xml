<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manual_to_wizard_form" model="ir.ui.view">
        <field name="name">custom.transfer.order.manual.wizard.form</field>
        <field name="model">custom.transfer.order.manual.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Transfer Order">
                <group>
                    <field name="product_id"/>
                    <field name="source_location_id"/>
                    <field name="target_location_id"/>
                    <field name="qty"/>
                    <field name="deadline_at"/>
                    <field name="priority"/>
                </group>
                <footer>
                    <button name="action_create" type="object" string="Create" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_manual_to_wizard" model="ir.actions.act_window">
        <field name="name">Manual Transfer Order</field>
        <field name="res_model">custom.transfer.order.manual.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
