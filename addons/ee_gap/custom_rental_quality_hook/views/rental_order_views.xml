<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_order_form_inherit_quality" model="ir.ui.view">
        <field name="name">rental.order.form.quality</field>
        <field name="model">rental.order</field>
        <field name="inherit_id" ref="custom_rental.view_rental_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_return']" position="after">
                <button name="action_open_quality_check" string="Open Quality Check"
                        type="object" class="btn-secondary"
                        invisible="not quality_check_id"/>
                <button name="action_create_maintenance_request" string="Report Damage"
                        type="object" class="btn-secondary"
                        invisible="state not in ('picked_up', 'returned')"/>
            </xpath>
            <xpath expr="//page[@name='bast']" position="after">
                <page string="Quality &amp; Maintenance">
                    <group>
                        <field name="quality_check_id" readonly="1"/>
                        <field name="maintenance_request_id" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
