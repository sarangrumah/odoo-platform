<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_barcode_scan_line_list" model="ir.ui.view">
        <field name="name">custom.barcode.scan.line.list</field>
        <field name="model">custom.barcode.scan.line</field>
        <field name="arch" type="xml">
            <list string="Scan Lines"
                  decoration-danger="status == 'not_found'"
                  decoration-warning="status == 'duplicate'"
                  decoration-muted="status == 'wrong_location'">
                <field name="scanned_at"/>
                <field name="session_id"/>
                <field name="raw_barcode"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="quantity"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_custom_barcode_scan_line_form" model="ir.ui.view">
        <field name="name">custom.barcode.scan.line.form</field>
        <field name="model">custom.barcode.scan.line</field>
        <field name="arch" type="xml">
            <form string="Scan Line">
                <sheet>
                    <group>
                        <group>
                            <field name="session_id"/>
                            <field name="scanned_at"/>
                            <field name="raw_barcode"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="quantity"/>
                            <field name="status" widget="badge"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_barcode_scan_line" model="ir.actions.act_window">
        <field name="name">Scan Lines</field>
        <field name="res_model">custom.barcode.scan.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
