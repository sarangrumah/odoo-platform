<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_barcode_format_list" model="ir.ui.view">
        <field name="name">custom.barcode.format.list</field>
        <field name="model">custom.barcode.format</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="prefix"/>
                <field name="suffix"/>
                <field name="sequence_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_custom_barcode_format_form" model="ir.ui.view">
        <field name="name">custom.barcode.format.form</field>
        <field name="model">custom.barcode.format</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="prefix"/>
                            <field name="suffix"/>
                            <field name="sequence_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Applied To Models"/>
                    <field name="applied_models" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_custom_barcode_format" model="ir.actions.act_window">
        <field name="name">Barcode Formats</field>
        <field name="res_model">custom.barcode.format</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
