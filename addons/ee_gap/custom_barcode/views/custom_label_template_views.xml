<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_label_template_list" model="ir.ui.view">
        <field name="name">custom.label.template.list</field>
        <field name="model">custom.label.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="paper_format"/>
                <field name="output_mode"/>
                <field name="applies_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_custom_label_template_form" model="ir.ui.view">
        <field name="name">custom.label.template.form</field>
        <field name="model">custom.label.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="paper_format"/>
                            <field name="width_mm"
                                   invisible="paper_format != 'custom'"/>
                            <field name="height_mm"
                                   invisible="paper_format != 'custom'"/>
                            <field name="output_mode"/>
                        </group>
                        <group>
                            <field name="applies_to"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Template Source"/>
                    <field name="template_source" widget="text" placeholder="ZPL or ESC/POS body with {{field}} placeholders"/>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_custom_label_template" model="ir.actions.act_window">
        <field name="name">Label Templates</field>
        <field name="res_model">custom.label.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
