# ============================================================
# Odoo 19 Platform — environment template
# Copy to .env and fill in all REQUIRED values before `make up`.
# Entrypoint will fail-fast on values containing the literal `changeme`.
# ============================================================

# ----- Compose project -----
COMPOSE_PROJECT_NAME=odoo19-platform

# ----- Ports (override jika bentrok dengan service lain di host) -----
ODOO_HTTP_PORT=18069
ODOO_LONGPOLL_PORT=18072
POSTGRES_PORT=15432
REDIS_PORT=16379
AI_GATEWAY_PORT=18080
PREDICTOR_PORT=18090
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
LOKI_PORT=13100
ALERTMANAGER_PORT=19093
PGADMIN_PORT=15050
MAILPIT_UI_PORT=18025
MAILPIT_SMTP_PORT=11025
NGINX_HTTP_PORT=18000
NGINX_HTTPS_PORT=18443
OLLAMA_PORT=11434

# ----- Secrets (WAJIB diganti — entrypoint fail-fast jika ada `changeme`) -----
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme-min-16-characters-required
POSTGRES_DB=postgres
ODOO_ADMIN_PASSWD=changeme-odoo-master-password
REDIS_PASSWORD=changeme-redis-pass-min-16
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-grafana
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme-pgadmin
GATEWAY_SHARED_SECRET=changeme-generate-with-openssl-rand-hex-32
CORETAX_SERTEL_MASTER_KEY=changeme-fernet-key-44-chars-base64urlsafe

# ----- AI providers -----
AI_PROVIDER=anthropic                          # anthropic | openai | ollama
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MODEL_QUALITY=claude-opus-4-7
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_DEFAULT=llama3.2

# ----- Odoo runtime -----
WORKERS=0                                      # dev=0, prod>=4
MAX_CRON_THREADS=2
LIST_DB=true                                   # prod=false
WITHOUT_DEMO=                                  # prod=all
LIMIT_TIME_CPU=600
LIMIT_TIME_REAL=1200
LIMIT_MEMORY_SOFT=2147483648
LIMIT_MEMORY_HARD=2684354560
LOG_LEVEL=info                                 # debug|info|warn|error|critical
PROXY_MODE=True
DBFILTER=^.*$
SERVER_WIDE_MODULES=base,web,queue_job

# ----- Network policy -----
EXPOSE_DB=false                                # true = postgres listen di host (dev only)
EXPOSE_REDIS=false

# ----- Observability -----
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=336h                            # 14 days
PREDICTOR_INTERVAL_HOURS=6
ALERTMANAGER_WEBHOOK_URL=                      # opsional: Slack/Discord webhook
ALERTMANAGER_EMAIL_TO=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ----- Predictor / capacity planning -----
HOST_CPU_CORES=8
HOST_RAM_GB=32
HOST_DISK_GB=500

# ----- TLS (prod) -----
TLS_CERT_PATH=./nginx/certs/server.crt
TLS_KEY_PATH=./nginx/certs/server.key

# ----- TLS / ACME (Caddy overlay: docker-compose.tls-acme.yml) -----
# Public DNS name terminating at this host. Leave default for local trials
# (Caddy will use its internal CA and issue a self-signed cert).
DOMAIN=localhost.localdomain
# Contact email for Let's Encrypt. Empty => Caddy local CA only.
ACME_EMAIL=
# Optional custom ACME directory (e.g. for staging or ZeroSSL/Buypass).
# Empty => Let's Encrypt production. Use the staging Caddyfile variant
# (caddy/Caddyfile.staging) for safe end-to-end testing.
ACME_CA_DIR=
# Host-side ports Caddy binds to (80/443 are the ACME-required defaults).
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ----- Backup (postgres-backup-s3 sidecar) -----
# S3 / S3-compatible object storage. Leave S3_ENDPOINT empty for AWS S3.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=ap-southeast-3
S3_PREFIX=odoo19-platform/postgres
S3_ENDPOINT=
# Backup retention (days) and cron schedule (standard 5-field cron).
BACKUP_KEEP_DAYS=30
SCHEDULE=@daily
