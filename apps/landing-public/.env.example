# Server-side only (do NOT prefix with NEXT_PUBLIC_)
ORCHESTRATOR_BASE_URL=http://orchestrator:8000
ORCHESTRATOR_SHARED_SECRET=change-me-must-be-32-chars-minimum-secret

# Client-exposed Turnstile site key (server reads TURNSTILE_SITE_KEY and re-exposes
# as NEXT_PUBLIC_TURNSTILE_SITE_KEY through next.config.js)
TURNSTILE_SITE_KEY=

# Optional: forwarded to orchestrator for Cloudflare server-side verify
# (orchestrator reads TURNSTILE_SECRET from its own env)
